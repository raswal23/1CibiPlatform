{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "OnePlatform_Connection": "${CONNECTIONSTRINGS__ONEPLATFORM_CONNECTION}",
    "TairRedis": "${CONNECTIONSTRINGS__TAIRREDIS}"
  },
  "Jwt": {
    "Key": "${JWT__KEY}",
    "Issuer": "${JWT__ISSUER}",
    "Audience": "${JWT__AUDIENCE}",
    "ExpiryInMinutes": "${JWT__EXPIRYINMINUTES}"
  },
  "HttpCookieOnlyKey": "${HTTPCOOKIEONLYKEY}",
  "AuthWeb": {
    "CookieExpiryInMinutes": "${AUTHWEB__COOKIEEXPIRYINMINUTES}",
    "CookieExpiryInDayIsRememberMe": "${AUTHWEB__COOKIEEXPIRYINDAYISREMEMBERME}",
    "AuthWebHttpCookieOnlyKey": "${AUTHWEB__AUTHWEBHTTPCOOKIEONLYKEY}",
    "IsHttps": "${AUTHWEB__ISHTTPS}",
    "AccountLockDurationInMinutes": "${AUTHWEB__ACCOUNTLOCKDURATIONINMINUTES}",
    "MaxFailedAttemptsBeforeLockout": "${AUTHWEB__MAXFAILEDATTEMPTSBEFORELOCKOUT}"
  },
  "FrontEndMetadata": {
    "AppName": "${FRONTENDMETADATA__APPNAME}",
    "AppVersion": "${FRONTENDMETADATA__APPVERSION}",
    "Url": "${FRONTENDMETADATA__URL}",
    "ForgotPasswordUrl": "${FRONTENDMETADATA__FORGOTPASSWORDURL}"
  },
  "CNXTalkpushsKey": {
    "Key": "${CNXTALKPUSHSKEY__KEY}",
    "FilterCheck": "${CNXTALKPUSHSKEY__FILTERCHECK}"
  },
  "Saml2": {
    "SpBaseUrl": "${SAML2__SPBASEURL}",
    "IdpEntityId": "${SAML2__IDPENTITYID}",
    "IdpMetadataUrl": "${SAML2__IDPMETADATAURL}"
  },
  "Email": {
    "Gmail": {
      "SenderEmail": "${EMAIL__GMAIL__SENDEREMAIL}",
      "AppPassword": "${EMAIL__GMAIL__APPPASSWORD}",
      "SmtpHost": "${EMAIL__GMAIL__SMTPHOST}",
      "SmtpPort": "${EMAIL__GMAIL__SMTPPORT}"
    },
    "OtpExpirationInMinutes": "${EMAIL__OTPEXPIRATIONINMINUTES}",
    "PasswordTokenExpirationInMinutes": "${EMAIL__PASSWORDTOKENEXPIRATIONINMINUTES}",
    "OtpMaxAttempts": "${EMAIL__OTPMAXATTEMPTS}"
  },
  "PhilSys": {
    "LivenessSessionExpiryInMinutes": "${PHILSYS__LIVENESSSESSIONEXPIRYINMINUTES}",
    "LivenessBaseUrl": "${PHILSYS__LIVENESSBASEURL}",
    "ClientID": "${PHILSYS__CLIENTID}",
    "ClientSecret": "${PHILSYS__CLIENTSECRET}",
    "LivenessSDKPublicKey": "${PHILSYS__LIVENESSSDKPUBLICKEY}"
  },
  "ATS": {
    "ApplicationFormBaseUrl": "${ATS__APPLICATIONFORMBASEURL}",
    "ATSApplicationFormExpiryInHours": "${ATS__ATSAPPLICATIONFORMEXPIRYINHOURS}",
    "ATSUploadFolderName": "${ATS__ATSUPLOADFOLDERNAME}",
    "ATSBulkTemplatePath": "${ATS__ATSBULKTEMPLATEPATH}"
  },
  "SSOMetadata": {
    "SigninScheme": "${SSOMETADATA__SIGNINSCHEME}",
    "UserEmailCookieName": "${SSOMETADATA__USEREMAILCOOKIENAME}",
    "BlazorAppUrl": "${SSOMETADATA__BLAZORAPPURL}"
  },
  "OpenAI": {
    "ApiKey": "${OPENAI__APIKEY}",
    "Endpoint": "${OPENAI__ENDPOINT}",
    "Model": "${OPENAI__MODEL}",
    "EmbeddingModel": "${OPENAI__EMBEDDINGMODEL}"
  },
  "SignalRHub": {
    "Endpoint": "${SIGNALRHUB__ENDPOINT}"
  },
  "AlibabaOss": {
    "Endpoint": "${ALIBABAOSS__ENDPOINT}",
    "BucketName": "${ALIBABAOSS__BUCKETNAME}",
    "AccessKeyId": "${ALIBABAOSS__ACCESSKEYID}",
    "AccessKeySecret": "${ALIBABAOSS__ACCESSKEYSECRET}"
  }
}
