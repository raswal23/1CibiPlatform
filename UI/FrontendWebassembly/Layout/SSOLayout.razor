@inject LocalStorageService LocalStorageService
@inject ISSOService SSOService
@inject NavigationManager NavigationManager
@inject IJSRuntime JS
@inherits LayoutComponentBase

<MudThemeProvider Theme="@_myTheme" @bind-IsDarkMode="@_isDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Style="@GetAppBarStyle()">
        <MudText Typo="Typo.h5" Class="ml-2 font-weight-bold">
            A P P L I C A T I O N S
        </MudText>
        <MudSpacer />
        <MudIconButton Icon="@(_isDarkMode? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                       Style="Color.Inherit"
                       OnClick="@ToggleDarkMode" />
        <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="@LogoutAsync" Class="ml-2">
            <MudIcon Icon="@Icons.Material.Filled.Logout" /> Logout
        </MudButton>
    </MudAppBar>

    <MudMainContent>
        <MudPaper Class="pa-5 ma-4" Elevation="2">
            @Body
        </MudPaper>
    </MudMainContent>
</MudLayout>

