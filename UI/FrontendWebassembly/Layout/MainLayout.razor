@inherits LayoutComponentBase
@inject NavigationManager Navigation
@inject IAuthService IAuthService
@inject LocalStorageService LocalStorageService
@inject IJSRuntime JS

<MudThemeProvider Theme="@_myTheme" @bind-IsDarkMode="@_isDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />
@if (!_isLoading)
{
    <ErrorBoundary>
        <ChildContent>

            <MudLayout>
                <!-- AppBar -->
                <MudAppBar Style="@GetAppBarStyle()" Class="mb-8 mt-0">
                    <MudIconButton Icon="@Icons.Material.Filled.Menu" Style="@GetMenuIconStyle()" Edge="Edge.Start" OnClick="@DrawerToggle" />
                    <MudSpacer />
                    <MudText Typo="Typo.subtitle1" Class="mr-2">Hi @name</MudText>
                    <MudIconButton Icon="@(_isDarkMode? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                                   Style="Color.Inherit;"
                                   OnClick="@ToggleDarkMode" />
                </MudAppBar>

                <!-- Drawer -->
                <MudDrawer @bind-Open="_drawerOpen"
                           Elevation="1"
                           Style="box-shadow: 0 0 30px rgba(0, 0, 0, 0.25); border-radius: 15px; display: flex; flex-direction: column;">

                    <MudDrawerHeader Style="@GetContainerStyle()">
                        <MudImage Src="images/logo/cibi.png"
                                  Alt="Cibi Logo"
                                  Style="width: 125px; height:45px; filter: drop-shadow(0 0 1px white) drop-shadow(0 0 2px white) drop-shadow(0 0 3px white);" />
                    </MudDrawerHeader>

                    <!-- Navigation menu that fills remaining space -->
                    <MudNavMenu Class="flex-grow-1">

                        @{
                            var combined = Apps
                            .Select((appId, index) => new
                            {
                                AppId = appId,
                                SubMenus = SubMenus[index]
                            })
                            .OrderBy(x =>
                            {
                                var(_, _, _) = ApplicationListDescriptionIcon.List[x.AppId];
                                return AppOrder.ContainsKey(x.AppId) ? AppOrder[x.AppId] : 100;
                            })
                            .ToList();
                        }

                        @foreach (var item in combined)
                        {
                            var (path, appDescription, appIcon) =
                            ApplicationListDescriptionIcon.List[item.AppId];

                            <MudNavGroup Title="@appDescription" Expanded="false" Icon="@appIcon">

                                @foreach (var subId in item.SubMenus)
                                {
                                    var (subPath, subDescription, subIcon) = SubMenuList.List[subId];

                                    // GENERAL → has children
                                    if (subDescription == "General")
                                    {
                                        <MudNavGroup Title="General" Icon="@subIcon" Expanded="false">

                                            <MudNavLink Href="@($"{path.ToLower()}/general/personal-settings")"
                                                        Match="NavLinkMatch.Prefix"
                                                        Icon="@Icons.Material.Filled.Person">
                                                Personal Settings
                                            </MudNavLink>

                                            <MudNavLink Href="@($"{path.ToLower()}/general/users")"
                                                        Match="NavLinkMatch.Prefix"
                                                        Icon="@Icons.Material.Filled.Group">
                                                Users
                                            </MudNavLink>

                                        </MudNavGroup>
                                    }
                                    // SECURITY CONTROL → has children
                                    else if (subDescription == "Security Control")
                                    {
                                        <MudNavGroup Title="Security Control" Icon="@subIcon" Expanded="false">

                                            <MudNavLink Href="@($"{path.ToLower()}/securitycontrol/profiles")"
                                                        Match="NavLinkMatch.Prefix"
                                                        Icon="@Icons.Material.Filled.Badge">
                                                Profiles
                                            </MudNavLink>

                                            <MudNavLink Href="@($"{path.ToLower()}/securitycontrol/territory-management")"
                                                        Match="NavLinkMatch.Prefix"
                                                        Icon="@Icons.Material.Filled.Map">
                                                Territory Management
                                            </MudNavLink>

                                            <MudNavLink Href="@($"{path.ToLower()}/securitycontrol/login-history")"
                                                        Match="NavLinkMatch.Prefix"
                                                        Icon="@Icons.Material.Filled.History">
                                                Login History
                                            </MudNavLink>

                                            <MudNavLink Href="@($"{path.ToLower()}/securitycontrol/audit-log")"
                                                        Match="NavLinkMatch.Prefix"
                                                        Icon="@Icons.Material.Filled.FactCheck">
                                                Audit Log
                                            </MudNavLink>

                                        </MudNavGroup>
                                    }
                                    // NORMAL submenu
                                    else
                                    {
                                        <MudNavLink Href="@($"{path.ToLower()}/{subPath.ToLower()}")"
                                                    Match="NavLinkMatch.Prefix"
                                                    Icon="@subIcon"
                                                    ActiveClass="@GetActiveNavClass()">
                                            @subDescription
                                        </MudNavLink>
                                    }
                                }

                            </MudNavGroup>
                        }

                    </MudNavMenu>

                    <!-- Logout at the very bottom -->
                    <div class="px-4 py-2 mt-auto">
                        <MudNavLink Icon="@Icons.Material.Filled.Logout"
                                    Match="NavLinkMatch.All"
                                    OnClick="HandleLogout">
                            Logout
                        </MudNavLink>
                    </div>
                </MudDrawer>
                <!-- Main content -->
                <MudMainContent>
                    <MudPaper Class="philsys-wrapper pa-5 ma-5" Elevation="2" Style="border-radius: 15px;">
                        @Body
                    </MudPaper>
                </MudMainContent>
            </MudLayout>

        </ChildContent>
        <ErrorContent Context="exception">
            <MudContainer Class="d-flex flex-column justify-center align-center oneplatform-generic-container" Style="gap: 20px;">
                <MudPaper Class="pa-8" Elevation="3" Style="max-width: 600px; text-align: center;">
                    <MudIcon Icon="@Icons.Material.Filled.Error" Color="Color.Error" Size="Size.Large" Class="mb-4" />
                    <MudText Typo="Typo.h4" Color="Color.Error" Class="mb-2">
                        Oops! Something went wrong
                    </MudText>
                    <MudText Typo="Typo.body1" Class="mb-4">
                        We encountered an unexpected error. Please try refreshing the page.
                    </MudText>
                    <MudExpansionPanels>
                        <MudExpansionPanel Text="Error Details">
                            <MudText Typo="Typo.body2" Style="font-family: monospace; white-space: pre-wrap; word-break: break-word;">
                                @exception.Message
                            </MudText>
                        </MudExpansionPanel>
                    </MudExpansionPanels>
                    <ButtonComponent OnClick="@(() => Navigation.NavigateTo(Navigation.Uri, true))"
                                     StartIcon="@Icons.Material.Filled.Refresh"
                                     Class="theme-button theme-button-active mt-4"
                                     Style="width: 200px; border-radius: 4px;">
                        Reload Page
                    </ButtonComponent>
                </MudPaper>
            </MudContainer>
        </ErrorContent>
    </ErrorBoundary>

}
else
{
    <!-- Loading -->
    <LoaderComponent />
}

