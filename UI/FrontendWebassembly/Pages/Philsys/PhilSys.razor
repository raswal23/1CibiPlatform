@page "/philsys/idv"
@layout MainLayout
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inherits SecurePageBase
@attribute [RequirePermission(2, 2)]
@* philsys/idv *@

<PageTitle>Identity Verification System</PageTitle>

<MudGrid Justify="Justify.Center">
    <MudItem xs="12" sm="12">

        <PhilSysFormTabComponent ActiveTabChanged="ChangeActiveTab" ></PhilSysFormTabComponent>

        <MudPaper Elevation="1" Class="p-4 philsys-form-container" Style="border-radius: 4px; box-shadow: 0 0 10px rgba(42,119,174,0.8); max-width: 380px;">
            @if (_activeIndex == 0)
            {
                <BasicInformationFormComponent />
            }
            else if (_activeIndex == 1)
            {
                <PhilSysCardNumbeFormComponent/>
            }
        </MudPaper>

    </MudItem>
</MudGrid>
