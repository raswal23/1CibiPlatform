@page "/invite-email"
@using FrontendWebassembly.DTO.ATS
@using FrontendWebassembly.Services.ATS.Interface
@inject IInsertEmailInvitationRequestService InsertEmailInvitationRequestService

<h3>Send Email Invitation</h3>

@if (isSubmitting)
{
    <p>Sending...</p>
}
else if (submitSuccess)
{
    <p class="mud-typography-body1">Invitation created: @createdId</p>
}

<EditForm Model="model" OnValidSubmit="HandleValidSubmit">
    <div>
        <label>First name</label>
        <InputText @bind-Value="model.FirstName" />
    </div>
    <div>
        <label>Last name</label>
        <InputText @bind-Value="model.LastName" />
    </div>
    <div>
        <label>Email</label>
        <InputText @bind-Value="model.EmailAddress" />
    </div>
    <div>
        <label>Mobile</label>
        <InputText @bind-Value="model.MobileNumber" />
    </div>

    <button type="submit">Send Invitation</button>
</EditForm>

@code {
    private EmailInvitationRequestDTO model = new();
    private bool isSubmitting;
    private bool submitSuccess;
    private Guid createdId;

    private async Task HandleValidSubmit()
    {
        try
        {
            isSubmitting = true;
            submitSuccess = false;

            // Ensure an ID is present if API expects one
            if (model.EmailInvitationID == Guid.Empty)
                model.EmailInvitationID = Guid.NewGuid();

            var result = await InsertEmailInvitationRequestService.InsertEmailInvitationRequest(model);
            createdId = result;
            submitSuccess = true;

            // Optionally reset form
            model = new EmailInvitationRequestDTO();
        }
        catch (Exception ex)
        {
            // Handle/log error as needed. For now show a browser alert.
            await JS.InvokeVoidAsync("alert", $"Failed to send invitation: {ex.Message}");
        }
        finally
        {
            isSubmitting = false;
        }
    }

    [Inject]
    private IJSRuntime JS { get; set; } = default!;
}
