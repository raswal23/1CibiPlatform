@page "/s&i/ats"
@layout MainLayout
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inherits SecurePageBase
@attribute [RequirePermission(6, 7)]

<PageTitle>WFS Talent Suite - Dashboard</PageTitle>

<MudContainer Class="pa-0">

    <!-- Logo + Title moved outside the MudGrid and pinned to the left -->
    <div class="d-flex align-center mb-3" style="gap:12px; align-items:center;">
        <div>
            <MudText Typo="Typo.h5" Class="mb-0" Color="Color.Primary">WFS Talent Suite</MudText>
        </div>
        <MudImage Src="/images/generic/cibi-icon.png" Alt="logo" Style="width:48px; height:48px;" />
    </div>

    <!-- Header (tabs + welcome) -->
    <MudGrid AlignItems="Center">
        <MudItem xs="12" Class="d-flex justify-center">
            <MudTabs 
                Rounded="false" 
                Elevation="0" 
                Class="custom-tabs"
                TabPanelsClass="pt-2 pb-2" 
                ScrollButtons="Auto"
                Style="max-width:100%; overflow-x:auto; margin-right: 0 !important; padding: 5px;">
                    <MudTabPanel Text="Dashboard" Onclick="@(() => ChangeActiveTab(0))" />
                    <MudTabPanel Text="New Order" Onclick="@(() => ChangeActiveTab(1))" />
                    <MudTabPanel Text="Dispute Order" Onclick="@(() => ChangeActiveTab(2))" />
                    <MudTabPanel Text="Search Report" Onclick="@(() => ChangeActiveTab(3))" />
                    <MudTabPanel Text="Invoice" Onclick="@(() => ChangeActiveTab(4))" />
                    <MudTabPanel Text="Settings" Onclick="@(() => ChangeActiveTab(5))" />
            </MudTabs>
        </MudItem>
    </MudGrid>

    <MudDivider Style="margin-bottom: 2px; height:2px; background-color:gray;" />

    <!-- Dashboard -->
     @if (_activeIndex == 0)
    {
        <MudGrid Class="mb-4" JustifyContent="Center" GutterSize="0">
            <MudItem xs="12" md="4">
                <MudPaper Elevation="1" Class="pa-4" Style="border-radius: 10px;  border: 1px solid gray;">
                    <MudText Typo="Typo.subtitle1" Align="Align.Center" Class="mb-2"> Job Offer Acceptance Rate</MudText>
                    <MudChart ChartType="ChartType.Donut"
                              Width="100%"
                              Height="200px"
                              ChartOptions="@donutChartOptions"
                              ChartSeries="@JobAcceptanceRates.AsChartDataSet()"
                              ChartLabels="@Departments">
                        <CustomGraphics>
                            <text class="mud-donut-text mud-typography-h3" x="50%" y="50%">@JobAcceptanceRates.Sum()</text>
                        </CustomGraphics>
                    </MudChart>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="4">
                <MudPaper Elevation="1" Class="pa-4" Style="border-radius: 4px; border: 1px solid gray; padding: 10px;">
                    <MudText Typo="Typo.subtitle1" Align="Align.Center" Class="mb-2">Year-To-Date Compliance</MudText>
                    <MudChart ChartType="ChartType.Bar"
                              ChartSeries="@BarSeries"
                              Width="100%"
                              ChartOptions="@barChartOptions"
                              ChartLabels="@BarLabels"
                              Height="200px" />
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="4">
                <MudPaper Elevation="1" Class="pa-4" Style="border-radius: 4px; border: 1px solid gray; padding: 10px;">
                    <MudText Typo="Typo.subtitle1" Align="Align.Center" Class="mb-2">Time-To-Hire Trend</MudText>
                    <MudChart ChartType="ChartType.Line"
                              ChartSeries="@LineSeries"
                              ChartLabels="@LineLabels"
                              ChartOptions="@lineChartOptions"
                              Width="100%"
                              Height="200px" />
                </MudPaper>
            </MudItem>
        </MudGrid>

        <!-- Recent transactions -->
        <TableComponent TItem="TransactionRow"
                        @ref="transactionsTable"
                        Title="Recent Transactions"
                        EnableSearch="true"
                        ColumnCount="4"
                        RowsPerPage="10"
                        LoadServerData="LoadTransactionData">

            <HeaderTemplate>
                <MudTh>Ticket Number</MudTh>
                <MudTh>Subject Name</MudTh>
                <MudTh>Status</MudTh>
                <MudTh>Result</MudTh>
            </HeaderTemplate>

            <RowTemplate Context="tx">
                <MudTd DataLabel="Ticket">@tx.Ticket</MudTd>
                <MudTd DataLabel="Subject">@tx.Subject</MudTd>
                <MudTd DataLabel="Status">@tx.Status</MudTd>
                <MudTd DataLabel="Result">@tx.Result</MudTd>
            </RowTemplate>

        </TableComponent>
    }
    else if (_activeIndex == 1)
    {
        <TableComponent TItem="OrderRow"
                        @ref="ordersTable"
                        Title="Completed Orders (Last 30 Days)"
                        EnableSearch="true"
                        ColumnCount="6"
                        RowsPerPage="10"
                        LoadServerData="LoadOrderData">

            <HeaderTemplate>
                <MudTh>Ticket Number</MudTh>
                <MudTh>Subject Name</MudTh>
                <MudTh>Status</MudTh>
                <MudTh>Result</MudTh>
                <MudTh>Date Completed</MudTh>
                <MudTh>Dispute</MudTh>
            </HeaderTemplate>

            <RowTemplate Context="o">
                <MudTd DataLabel="Ticket Number">@o.TicketNumber</MudTd>
                <MudTd DataLabel="Subject Name">@o.SubjectName</MudTd>
                <MudTd DataLabel="Status">@o.Status</MudTd>
                <MudTd DataLabel="Result">@o.Result</MudTd>
                <MudTd DataLabel="Date Completed">@o.DateCompleted</MudTd>
                <MudTd>
                    <div style="display:flex; justify-content:center; align-items:center;">
                        <MudCheckBox T="bool" @bind-Checked="o.Dispute" Color="Color.Primary" />
                    </div>
                </MudTd>
            </RowTemplate>
        </TableComponent>

        <MudGrid Class="mt-3" >
            <MudItem xs="12" Class="d-flex justify-center">
                <MudText Align="Align.Center" Typo="Typo.caption" Color="Color.Primary">
                <b>IMPORTANT NOTICE!</b><br />
                To preserve data and result integrity, dispute process can only be submitted for orders compieted within the last 30 days.
                </MudText>
            </MudItem>
            <MudItem xs="12" Class="d-flex justify-center">
                <MudText Align="Align.Center" Typo="Typo.caption" Color="Color.Primary">
                    Please submit an order if more than 30 days or if reverification is required for the selected individual.
                </MudText>
            </MudItem>
        </MudGrid>
    }
    else if (_activeIndex == 2)
    {
        <!-- New Order -->
        <MudGrid GutterSize="3" Class="mb-4">
            <MudItem xs="12" md="6">
                <MudPaper Elevation="1" Class="pa-4 mb-3" Style="border-radius: 10px;  border: 1px solid gray;">
                    <MudText Typo="Typo.subtitle1" Align="Align.Center" Class="mb-2">Candidate Details</MudText>

                    <MudForm @ref="candidateForm">
                        <MudGrid Spacing="2">
                            <MudItem xs="12" sm="5">
                                    <MudTextField @bind-Value="candidate.LastName" Placeholder="Last Name" Variant="Variant.Outlined" Class="philsys-rounded-input" />
                            </MudItem>

                            <MudItem xs="12" sm="5">
                                <MudTextField @bind-Value="candidate.LastName" Placeholder="Last Name" Variant="Variant.Outlined" Class="philsys-rounded-input" />
                            </MudItem>

                            <MudItem xs="12" sm="2">
                                <MudTextField @bind-Value="candidate.MiddleInitial" Placeholder="M.I." Variant="Variant.Outlined" Class="philsys-rounded-input" />
                            </MudItem>

                            <MudItem xs="12">
                                <MudTextField @bind-Value="candidate.Email" Label="Email Address" Variant="Variant.Outlined" FullWidth="true" Class="philsys-rounded-input" />
                            </MudItem>

                            <MudItem xs="12">
                                <MudTextField @bind-Value="candidate.Mobile" Label="Mobile Number" Variant="Variant.Outlined" FullWidth="true" Class="philsys-rounded-input" />
                            </MudItem>

                            <MudItem xs="12">
                                <MudSelect @bind-Value="candidate.Package" Label="Select Package" Variant="Variant.Outlined" FullWidth="true" Class="philsys-rounded-input">
                                    <MudSelectItem Value="@("Basic")">Basic</MudSelectItem>
                                    <MudSelectItem Value="@("Basic 2")">Basic 2</MudSelectItem>
                                    <MudSelectItem Value="@("Lite")">Lite</MudSelectItem>
                                    <MudSelectItem Value="@("Package 1")">Package 1</MudSelectItem>
                                    <MudSelectItem Value="@("AirBNB")">AirBNB</MudSelectItem>
                                </MudSelect>
                            </MudItem>

                            <MudItem xs="12" Class="d-flex align-center" Style="gap:12px;">
                                <MudRadioGroup @bind-Value="candidate.IsRush">
                                    <MudRadio Color="Color.Primary" Value="@("Normal")">Normal</MudRadio>
                                    <MudRadio Color="Color.Primary" Value="@("Rush")">Rush</MudRadio>
                                </MudRadioGroup>
                                <MudSpacer />
                                <MudButton Class="theme-button theme-button-active mt-4" Style="width:120px; border-radius: 4px;" OnClick="SubmitCandidate">Send</MudButton>
                            </MudItem>
                        </MudGrid>
                    </MudForm>
                </MudPaper>

                <MudPaper Elevation="1" Class="pa-4" Style="border-radius: 10px;  border: 1px solid gray;">
                    <MudText Align="Align.Center" Class="mb-2">Bulk Invite</MudText>

                    <MudGrid>
                        <MudItem xs="12">
                            <MudFileUpload @ref="@_fileUploadMultiple"
                                           @bind-Files="_filesMultiple"
                                           SelectedTemplate="@(files => builder => { })"
                                           AppendMultipleFiles>
                                <CustomContent>
                                    <div style="display: flex; justify-content: center;">
                                        <MudButton Class="philsys-rounded-input"
                                                   Style="width:300px; border: 1px solid gray; border-radius: 4px;"
                                                   StartIcon="@Icons.Material.Filled.CloudUpload">
                                            Upload .xls or .csv file
                                        </MudButton>
                                    </div>
                                </CustomContent>
                            </MudFileUpload>
                        </MudItem>

                        <MudItem xs="12" Class="d-flex justify-center">
                                <MudButton Class="theme-button theme-button-active" Style="width: 200px; border-radius: 4px;" OnClick="ProcessBulkInvite">Upload</MudButton>
                        </MudItem>
                    </MudGrid>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="6">
                <MudPaper Elevation="1" Class="pa-4" Style="height:100%; border-radius: 10px;  border: 1px solid gray;">
                    <MudText Align="Align.Center" Class="mb-2">Application Form</MudText>
                    <div style="height:520px; overflow:auto; padding:8px; background:#fff;">
                        <iframe src="/ats/ApplicationForm.pdf" style="width:100%; height:100%; border:0;" />
                        <noscript>
                            <MudText Typo="Typo.body2">Please download the application form from the link below.</MudText>
                        </noscript>
                    </div>
                </MudPaper>
            </MudItem>
        </MudGrid>
    }
    else if (_activeIndex == 3)
    {
        <!-- Invoice - componentized to match the provided image layout -->
        <TableComponent TItem="ReportRow"
                        @ref="reportsTable"
                        Title="Query Results"
                        EnableSearch="true"
                        ColumnCount="8"
                        RowsPerPage="10"
                        LoadServerData="LoadReportData">

            <HeaderTemplate>
                <MudTh>Selected</MudTh> 
                <MudTh>Subject Name</MudTh>
                <MudTh>Ticket Number</MudTh>
                <MudTh>Status</MudTh>
                <MudTh>Result</MudTh>
                <MudTh>Date Completed</MudTh>
                <MudTh>Report Type</MudTh>
                <MudTh>Dir</MudTh>
            </HeaderTemplate>

            <RowTemplate Context="r">
                <MudTd>
                    <div style="display:flex; justify-content:center; align-items:center;">
                        <MudCheckBox T="bool" @bind-Checked="r.Selected" Color="Color.Primary" />
                    </div>
                </MudTd>
                <MudTd DataLabel="Subject">@r.Subject</MudTd>
                <MudTd DataLabel="Ticket">@r.Ticket</MudTd>
                <MudTd DataLabel="Status">@r.Status</MudTd>
                <MudTd DataLabel="Result">@r.Result</MudTd>
                <MudTd DataLabel="Date">@r.DateCompleted</MudTd>
                <MudTd DataLabel="Type">@r.ReportType</MudTd>
                <MudTd>
                    <MudIconButton Icon="@Icons.Material.Filled.FileDownload" Color="Color.Primary" Size="Size.Small" OnClick="@(() => DownloadReport(r))" />
                </MudTd>
            </RowTemplate>

        </TableComponent>

        <MudGrid Class="mt-3" AlignItems="Center">
            <MudItem xs="12" md="8">
                <MudButton Class="theme-button theme-button-active mt-4"
                           Style="width: 120px; border-radius: 4px;"
                           OnClick="DownloadSelected">Download</MudButton>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudText Typo="Typo.caption" Class="text-right" Color="Color.Primary">
                    <b>IMPORTANT NOTICE!</b><br />
                    For security purposes, all reports downloaded are password protected and in PDF format. Please reach out to your account manager for your quarterly passwords.
                </MudText>
            </MudItem>
        </MudGrid>
    }
    else if (_activeIndex == 4)
    {
        <!-- Invoice -->
        <MudGrid GutterSize="3" Class="mb-4">
            <MudItem xs="12" md="6">
                <MudPaper Elevation="1" Class="pa-4 mb-3" Style="border-radius: 10px;  border: 1px solid gray;">
                    <div class="d-flex align-center" style="gap:12px;">
                        <MudText Typo="Typo.caption" Style="min-width:120px;">
                            Billed Date
                        </MudText>

                        <MudTextField @bind-Value="_date"
                                      Label="Billed Date"
                                      InputType="InputType.Date"
                                      FullWidth="true"
                                      Required="true"
                                      ReadOnly
                                      RequiredError="Billed Date is required"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Min="2000-01-01"
                                      Max="@DateTime.Today.ToString("yyyy-MM-dd")"
                                      Class="philsys-rounded-input" />
                    </div>
                </MudPaper>

                <MudPaper Elevation="1" Class="pa-4" Style="border-radius: 10px;  border: 1px solid gray;">
                    <MudText Typo="Typo.subtitle1" Align="Align.Center" Class="mb-2">Summary Details</MudText>

                    <MudGrid Spacing="2">
                        <MudItem xs="12" sm="5">
                            <MudTextField @bind-Value="candidate.LastName" Placeholder="Billing Statement" Variant="Variant.Outlined" Class="philsys-rounded-input" />
                        </MudItem>

                        <MudItem xs="12" sm="5">
                            <MudTextField @bind-Value="candidate.LastName" Placeholder="Due Date" Variant="Variant.Outlined" Class="philsys-rounded-input" />
                        </MudItem>

                        <MudItem xs="12" sm="2">
                            <MudTextField @bind-Value="candidate.MiddleInitial" Placeholder="Amount Due" Variant="Variant.Outlined" Class="philsys-rounded-input" />
                        </MudItem>

                        <MudItem xs="12">
                            <MudTextField @bind-Value="candidate.Email" Label="Previous Balance" Variant="Variant.Outlined" FullWidth="true" Class="philsys-rounded-input" />
                        </MudItem>

                        <MudItem xs="12">
                            <MudTextField @bind-Value="candidate.Mobile" Label="Total Amount Due" Variant="Variant.Outlined" FullWidth="true" Class="philsys-rounded-input" />
                        </MudItem>

                    </MudGrid>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="6">
                <MudPaper Elevation="1" Class="pa-4" Style="height:100%; border-radius: 10px;  border: 1px solid gray;">
                    <MudText Align="Align.Center" Class="mb-2">Payment Options</MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>
    }
   
    else if (_activeIndex == 5)
    {
        <!-- Invoice -->
    <MudText Typo="Typo.h6" Align="Align.Center" Class="mt-4">Invoice - Coming Soon!</MudText>
    }
</MudContainer>

@code {
    private TableComponent<TransactionRow>? transactionsTable;
    private int _activeIndex = 0;

    private void ChangeActiveTab(int value)
    {
        _activeIndex = value;
    }

    private readonly List<TransactionRow> _dummyTransactions = new()
    {
        new TransactionRow("2025 - 00123456", "Antonio Aguinaldo", "Completed", "Clear"),
        new TransactionRow("2025 - 00129876", "Teodoro Mabini", "Completed", "Clear"),
        new TransactionRow("2025 - 00124356", "Maria Quezon", "Completed", "Not Clear"),
        new TransactionRow("2025 - 00198765", "Angela Osmena", "Pending", "In Progress")
    };

    private record TransactionRow(string Ticket, string Subject, string Status, string Result);

    private Task<TableData<TransactionRow>> LoadTransactionData(TableState state, CancellationToken cancellationToken)
    {
        return Task.FromResult(new TableData<TransactionRow>
        {
            Items = _dummyTransactions,
            TotalItems = _dummyTransactions.Count
        });
    }

    private static readonly int[] JobAcceptanceRates = { 85, 70, 92, 60 };
    private TableComponent<ReportRow>? reportsTable;
    private TableComponent<OrderRow>? ordersTable;
    private static readonly string[] Departments = { "IT", "Marketing", "Sales", "HR" };

    private static readonly string[] ChartPalette =
    {
        "#102247", // 0%
        "#2a77ae", // 33%
        "#68c0d6", // 66%
        "#a0e0eb"  // 100%
    };

    // Candidate form
    private MudForm? candidateForm;
    private Candidate candidate = new();

    private class Candidate
    {
        public string LastName { get; set; } = string.Empty;
        public string FirstName { get; set; } = string.Empty;
        public string MiddleInitial { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public string Mobile { get; set; } = string.Empty;
        public string Package { get; set; } = string.Empty;
        public string IsRush { get; set; } = string.Empty;
    }

    private async Task SubmitCandidate()
    {
        await candidateForm!.Validate();
        // Basic client-side check
        if (!candidateForm.IsValid)
        {
            await JS.InvokeVoidAsync("console.warn", "Candidate form invalid");
            return;
        }

        // Replace with actual submit logic (API call)
        await JS.InvokeVoidAsync("console.log", "Candidate submitted", candidate);
    }

    private IReadOnlyList<IBrowserFile> _filesMultiple = [];
    private IList<IBrowserFile> _files => (_filesMultiple ?? Enumerable.Empty<IBrowserFile>())
        .Concat(_filesPDF != null ? new[] { _filesPDF } : Enumerable.Empty<IBrowserFile>())
        .Concat(_filesImages ?? Enumerable.Empty<IBrowserFile>())
        .ToList();
    private MudFileUpload<IReadOnlyList<IBrowserFile>> _fileUploadMultiple = default!;
    private MudFileUpload<IBrowserFile> _fileUploadPDF = default!;
    private MudFileUpload<IReadOnlyList<IBrowserFile>> _fileUploadImages = default!;
    private bool _uploading;
    private int _progress;
    private IBrowserFile? _filesPDF;
    private IReadOnlyList<IBrowserFile> _filesImages = [];
    private string _statusText = "Waiting for files.";

    private async Task UploadFilesAsync()
    {
        if (!_files.Any())
        {
            _statusText = "No files to upload.";
            return;
        }

        // Create a snapshot of the files to avoid altering the collection during iteration
        var filesSnapshot = _files.ToList();

        _uploading = true;
        _progress = 0;
        _statusText = "Uploading...";

        var total = filesSnapshot.Count;
        for (var index = 0; index < total; index++)
        {
            var file = filesSnapshot[index];
            await Task.Delay(1000); // Simulate file upload
            _progress = (int)Math.Round((index + 1d) / total * 100);
            _statusText = index + 1 == total ? "Upload complete." : $"Uploading {index + 1} of {total}...";
            await RemoveFileFromUploadsAsync(file);
            await InvokeAsync(StateHasChanged);
        }

        _uploading = false;
        await InvokeAsync(StateHasChanged);
    }

    private async Task RemoveFileFromUploadsAsync(IBrowserFile file)
    {
        var fileUploads = new object[] { _fileUploadMultiple, _fileUploadPDF, _fileUploadImages };

        foreach (var fileUpload in fileUploads)
        {
            if (fileUpload is MudFileUpload<IReadOnlyList<IBrowserFile>> multipleUpload && await multipleUpload.RemoveFileAsync(file))
            {
                return; // File removed from multiple files upload
            }

            if (fileUpload is MudFileUpload<IBrowserFile> singleUpload && await singleUpload.RemoveFileAsync(file))
            {
                return; // File removed from single file upload
            }
        }
    }

    // Bulk invite
    private IReadOnlyList<IBrowserFile>? uploadedFiles;

    private async Task ProcessBulkInvite()
    {
        if (uploadedFiles == null || !uploadedFiles.Any())
        {
            await JS.InvokeVoidAsync("console.warn", "No files selected for bulk invite");
            return;
        }

        // Placeholder: read first file name and log. Replace with server upload logic.
        await JS.InvokeVoidAsync("console.log", "Processing bulk invite", uploadedFiles.Select(f => f.Name));
    }

    // New: Report / Invoice table data and query fields
    private readonly List<ReportRow> _dummyReports = new()
    {
        new ReportRow(false, "Antonio Aguinaldo", "2025 - 00123456", "In Progress", "Pending", "October 25, 2025", "Basic"),
        new ReportRow(false, "Antonio Aguinaldo", "2025 - 00129876", "Completed", "Clear", "October 21, 2025", "Basic 2"),
        new ReportRow(false, "Antonio Aguinaldo", "2024 - 00124356", "Completed", "Not Clear", "October 20, 2024", "Lite"),
        new ReportRow(false, "Antonio Aguinaldo", "2023 - 00198765", "Completed", "Clear", "October 18, 2019", "Package 1"),
        new ReportRow(false, "Antonio Aguinaldo", "2019 - 00198765", "Completed", "Clear", "October 10, 2018", "AirBNB")
    };

    private class ReportRow
    {
        public bool Selected { get; set; }
        public string Subject { get; set; }
        public string Ticket { get; set; }
        public string Status { get; set; }
        public string Result { get; set; }
        public string DateCompleted { get; set; }
        public string ReportType { get; set; }

        public ReportRow(bool selected, string subject, string ticket, string status, string result, string dateCompleted, string reportType)
        {
            Selected = selected;
            Subject = subject;
            Ticket = ticket;
            Status = status;
            Result = result;
            DateCompleted = dateCompleted;
            ReportType = reportType;
        }
    }

    private Task<TableData<ReportRow>> LoadReportData(TableState state, CancellationToken cancellationToken)
    {
        // For now returns static results filtered by name query (simple contains)
        var filtered = _dummyReports.ToList();

        return Task.FromResult(new TableData<ReportRow>
        {
            Items = filtered,
            TotalItems = filtered.Count
        });
    }

    private async Task DownloadSelected()
    {
        var selected = _dummyReports.Where(r => r.Selected).ToList();
        if (!selected.Any())
        {
            // nothing selected - no-op or show message (JS console for now)
            await JS.InvokeVoidAsync("console.warn", "No reports selected for download.");
            return;
        }

        // placeholder: log selected items (replace with real download implementation)
        await JS.InvokeVoidAsync("console.log", $"Downloading {selected.Count} reports.", selected.Select(r => r.Ticket));
    }

    private async Task DownloadReport(ReportRow row)
    {
        // placeholder single-download behavior
        await JS.InvokeVoidAsync("console.log", $"Downloading report {row.Ticket}");
    }

    // Dispute Order - reusing ReportRow for simplicity, but can be a different model if needed
    private readonly List<OrderRow> _dummyOrders = new()
    {
        new OrderRow("2025 - 00123456", "Antonio Aguinaldo", "Completed", "Clear", "October 25, 2025", false),
        new OrderRow("2025 - 00129876", "Teodoro Mabini", "Completed", "Clear", "October 21, 2025", false),
        new OrderRow("2025 - 00124356", "Maria Quezon", "Completed", "Not Clear", "October 20, 2025", false),
        new OrderRow("2025 - 00198765", "Leonardo Roxas", "Completed", "Not Clear", "October 18, 2025", false),
        new OrderRow("2025 - 00198765", "Joseph Escoda", "Completed", "Not Clear", "October 18, 2025", false),
        new OrderRow("2025 - 00198765", "Francis Macapagal", "Completed", "Clear", "October 10, 2025", false),
        new OrderRow("2025 - 00198765", "Kris Aquino","Completed", "Not Clear", "October 9, 2025", false)
    };

    private class OrderRow
    {
        public string TicketNumber { get; set; }
        public string SubjectName { get; set; }
        public string Status { get; set; }
        public string Result { get; set; }
        public string DateCompleted { get; set; }
        public bool Dispute { get; set; }

        public OrderRow(string ticketNumber, string subjectName, string status, string result, string dateCompleted, bool dispute)
        {
            TicketNumber = ticketNumber;
            SubjectName = subjectName;
            Status = status;
            Result = result;
            DateCompleted = dateCompleted;
            Dispute = dispute;
        }
    }

    private Task<TableData<OrderRow>> LoadOrderData(TableState state, CancellationToken cancellationToken)
    {
        // For now returns static results filtered by name query (simple contains)
        var filtered = _dummyOrders.ToList();

        return Task.FromResult(new TableData<OrderRow>
        {
            Items = filtered,
            TotalItems = filtered.Count
        });
    }


