<MudDialog Style="padding: 8px;">
    <DialogContent>
        <MudGrid GutterSize="3" Class="mb-4">
            <MudItem xs="12" >
                <MudPaper Elevation="1" Class="pa-4 d-flex flex-column"
                          Style="height:100%; border-radius: 10px; border: 1px solid gray;">
                    
                    <MudGrid Spacing="2">
                        <MudItem xs="2" class="d-flex align-center">
                            <MudText>Subject Name</MudText>
                        </MudItem>
                        <MudItem xs="4">
                            <MudTextField @bind-Value="subject.SubjectName"
                                          Variant="Variant.Outlined"
                                          FullWidth="true"
                                          ReadOnly
                                          Class="oneplatform-rounded-input" />
                        </MudItem>

                        <MudItem xs="2" class="d-flex align-center">
                            <MudText>E-Pass Score</MudText>
                        </MudItem>
                        <MudItem xs="4">
                            <MudTextField @bind-Value="subject.Score"
                                          Variant="Variant.Outlined"
                                          FullWidth="true"
                                          ReadOnly
                                          Class="oneplatform-rounded-input" />
                        </MudItem>
                    </MudGrid>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="6">
                <MudPaper Elevation="1" Class="pa-4 d-flex flex-column"
                          Style="height:100%; border-radius: 10px; border: 1px solid gray;">

                    <MudGrid Spacing="2">

                        <MudItem xs="4" class="d-flex align-center">
                            <MudText>Ticket Number</MudText>
                        </MudItem>
                        <MudItem xs="8">
                            <MudTextField @bind-Value="ticketDetails.TicketNumber"
                                          Variant="Variant.Outlined"
                                          FullWidth="true"
                                          ReadOnly
                                          Class="oneplatform-rounded-input" />
                        </MudItem>

                        <MudItem xs="4" class="d-flex align-center">
                            <MudText>Status</MudText>
                        </MudItem>
                        <MudItem xs="8">
                            <MudTextField @bind-Value="ticketDetails.Status"
                                          Variant="Variant.Outlined"
                                          FullWidth="true"
                                          ReadOnly
                                          Class="oneplatform-rounded-input" />
                        </MudItem>

                        <MudItem xs="4" class="d-flex align-center">
                            <MudText>Result</MudText>
                        </MudItem>
                        <MudItem xs="8">
                            <MudTextField @bind-Value="ticketDetails.Result"
                                          Variant="Variant.Outlined"
                                          FullWidth="true"
                                          ReadOnly
                                          Class="oneplatform-rounded-input" />
                        </MudItem>

                        <MudItem xs="4" class="d-flex align-center">
                            <MudText>Report Type</MudText>
                        </MudItem>
                        <MudItem xs="8">
                            <MudTextField @bind-Value="ticketDetails.ReportType"
                                          Variant="Variant.Outlined"
                                          FullWidth="true"
                                          ReadOnly
                                          Class="oneplatform-rounded-input" />
                        </MudItem>

                        <MudItem xs="4" class="d-flex align-center">
                            <MudText>Aptitude Test</MudText>
                        </MudItem>
                        <MudItem xs="8">
                            <MudTextField @bind-Value="ticketDetails.AptitudeTest"
                                          Variant="Variant.Outlined"
                                          FullWidth="true"
                                          ReadOnly
                                          Class="oneplatform-rounded-input" />
                        </MudItem>

                        <MudItem xs="4" class="d-flex align-center">
                            <MudText>Live Interview</MudText>
                        </MudItem>
                        <MudItem xs="8">
                            <MudTextField @bind-Value="ticketDetails.LiveInterview"
                                          Variant="Variant.Outlined"
                                          FullWidth="true"
                                          ReadOnly
                                          Class="oneplatform-rounded-input" />
                        </MudItem>

                        <MudItem xs="4" class="d-flex align-center">
                            <MudText>Grammar</MudText>
                        </MudItem>
                        <MudItem xs="8">
                            <MudTextField @bind-Value="ticketDetails.Grammar"
                                          Variant="Variant.Outlined"
                                          FullWidth="true"
                                          ReadOnly
                                          Class="oneplatform-rounded-input" />
                        </MudItem>

                        <MudItem xs="4" class="d-flex align-center">
                            <MudText>Comprehension</MudText>
                        </MudItem>
                        <MudItem xs="8">
                            <MudTextField @bind-Value="ticketDetails.Comprehension"
                                          Variant="Variant.Outlined"
                                          FullWidth="true"
                                          ReadOnly
                                          Class="oneplatform-rounded-input" />
                        </MudItem>

                        <MudItem xs="4" class="d-flex align-center">
                            <MudText>Relativeness</MudText>
                        </MudItem>
                        <MudItem xs="8">
                            <MudTextField @bind-Value="ticketDetails.Relativeness"
                                          Variant="Variant.Outlined"
                                          FullWidth="true"
                                          ReadOnly
                                          Class="oneplatform-rounded-input" />
                        </MudItem>

                        <MudItem xs="12" Class="d-flex justify-center">
                            <MudButton Class="theme-button theme-button-active mt-5" Style="width: 200px; border-radius: 4px;" OnClick="ProcessBulkInvite">Download</MudButton>
                        </MudItem>
                    </MudGrid>

                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="6">
                <MudPaper Elevation="1" Class="pa-4 d-flex flex-column"
                          Style="height:100%; border-radius: 10px; border: 1px solid gray;">

                    <MudGrid Spacing="2">
                        <MudItem xs="4" class="d-flex align-center">
                            <MudText>Resume / CV</MudText>
                        </MudItem>
                        <MudItem xs="4">
                            <MudTextField @bind-Value="fileDetails.Resume"
                                          Variant="Variant.Outlined"
                                          FullWidth="true"
                                          ReadOnly
                                          Class="oneplatform-rounded-input" />
                        </MudItem>
                        <MudItem xs="4">
                            <MudTextField @bind-Value="fileDetails.UploadedDate"
                                          Variant="Variant.Outlined"
                                          FullWidth="true"
                                          ReadOnly
                                          Class="oneplatform-rounded-input" />
                        </MudItem>

                        <MudItem xs="4" class="d-flex align-center">
                            <MudText>ID Uploaded</MudText>
                        </MudItem>
                        <MudItem xs="4">
                            <MudTextField @bind-Value="fileDetails.ID"
                                          Variant="Variant.Outlined"
                                          FullWidth="true"
                                          ReadOnly
                                          Class="oneplatform-rounded-input" />
                        </MudItem>
                        <MudItem xs="4">
                            <MudTextField @bind-Value="fileDetails.UploadedDate"
                                          Variant="Variant.Outlined"
                                          FullWidth="true"
                                          ReadOnly
                                          Class="oneplatform-rounded-input" />
                        </MudItem>

                        <MudItem xs="4" class="d-flex align-center">
                            <MudText>COE</MudText>
                        </MudItem>
                        <MudItem xs="4">
                            <MudTextField @bind-Value="fileDetails.COE"
                                          Variant="Variant.Outlined"
                                          FullWidth="true"
                                          ReadOnly
                                          Class="oneplatform-rounded-input" />
                        </MudItem>
                        <MudItem xs="4">
                            <MudTextField @bind-Value="fileDetails.UploadedDate"
                                          Variant="Variant.Outlined"
                                          FullWidth="true"
                                          ReadOnly
                                          Class="oneplatform-rounded-input" />
                        </MudItem>

                        <MudItem xs="4" class="d-flex align-center">
                            <MudText>Diploma / TOR</MudText>
                        </MudItem>
                        <MudItem xs="4">
                            <MudTextField @bind-Value="fileDetails.Diploma"
                                          Variant="Variant.Outlined"
                                          FullWidth="true"
                                          ReadOnly
                                          Class="oneplatform-rounded-input" />
                        </MudItem>
                        <MudItem xs="4">
                            <MudTextField @bind-Value="fileDetails.UploadedDate"
                                          Variant="Variant.Outlined"
                                          FullWidth="true"
                                          ReadOnly
                                          Class="oneplatform-rounded-input" />
                        </MudItem>

                        <MudItem xs="4" class="d-flex align-center">
                            <MudText>Biometric Photo</MudText>
                        </MudItem>
                        <MudItem xs="4">
                            <MudTextField @bind-Value="fileDetails.BiometricPhoto"
                                          Variant="Variant.Outlined"
                                          FullWidth="true"
                                          ReadOnly
                                          Class="oneplatform-rounded-input" />
                        </MudItem>
                        <MudItem xs="4">
                            <MudTextField @bind-Value="fileDetails.UploadedDate"
                                          Variant="Variant.Outlined"
                                          FullWidth="true"
                                          ReadOnly
                                          Class="oneplatform-rounded-input" />
                        </MudItem>

                        <MudItem xs="4" class="d-flex align-center">
                            <MudText>Consent Form</MudText>
                        </MudItem>
                        <MudItem xs="4">
                            <MudTextField @bind-Value="fileDetails.ConsentForm"
                                          Variant="Variant.Outlined"
                                          FullWidth="true"
                                          ReadOnly
                                          Class="oneplatform-rounded-input" />
                        </MudItem>
                        <MudItem xs="4">
                            <MudTextField @bind-Value="fileDetails.UploadedDate"
                                          Variant="Variant.Outlined"
                                          FullWidth="true"
                                          Class="oneplatform-rounded-input" />
                        </MudItem>

                        <MudItem xs="4" class="d-flex align-center">
                            <MudText>Status</MudText>
                        </MudItem>
                        <MudItem xs="4">
                            <MudTextField @bind-Value="fileDetails.FinalReport"
                                          Variant="Variant.Outlined"
                                          FullWidth="true"
                                          ReadOnly
                                          Class="oneplatform-rounded-input" />
                        </MudItem>
                        <MudItem xs="4">
                            <MudTextField @bind-Value="fileDetails.UploadedDate"
                                          Variant="Variant.Outlined"
                                          FullWidth="true"
                                          ReadOnly
                                          Class="oneplatform-rounded-input" />
                        </MudItem>
                    </MudGrid>

                </MudPaper>
            </MudItem>
        </MudGrid>
    </DialogContent>

    <DialogActions>
        <MudButton Color="Color.Primary"
                   OnClick="Okay"
                   Class="theme-button theme-button-active"
                   Style="border-radius: 4px;">
            Okay
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    private MudForm? form;
    private TicketDetails ticketDetails = new();
    private Subject subject = new();
    private FileDetails fileDetails = new();

    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }

    [Parameter]
    public AddRoleDTO Role { get; set; } = new AddRoleDTO();

    void Okay() => MudDialog.Cancel();

    private class Subject
    {
        public string SubjectName { get; set; } = "Antonio Aguinaldo";
        public string Score { get; set; } = "85%";
    }

    private class TicketDetails
    {
        public string TicketNumber { get; set; } = "2025 - 00123456";
        public string Status { get; set; } = "Completed";
        public string Result { get; set; } = "Clear";
        public string ReportType { get; set; } = "Basic";
        public string AptitudeTest { get; set; } = "Passed - 90%";
        public string LiveInterview { get; set; } = "Completed";
        public string Grammar { get; set; } = "Passed - 85%";
        public string Comprehension { get; set; } = "Good";
        public string Relativeness { get; set; } = "Good";
    }

    private class FileDetails
    {
        public string Resume { get; set; } = "TonCV.pdf";
        public string ID { get; set; } = "TonID.jpg";
        public string COE { get; set; } = "TonCOE.pdf";
        public string Diploma { get; set; } = "TonTOR.pd";
        public string BiometricPhoto { get; set; } = "123-456.jpg";
        public string ConsentForm { get; set; } = "Consent_Form.pdf";
        public string FinalReport { get; set; } = "2025-00123456";
        public string UploadedDate { get; set; } = "October 19, 2025";
    }

    private async Task ProcessBulkInvite()
    {
    }
}
