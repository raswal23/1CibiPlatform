                                                Email
                                            </MudRadio>
                                            <MudRadio T="string" Class="small-checkbox-label" Value="@("Phone")">
                                                Phone
                                            </MudRadio>
                                            <MudRadio T="string" Class="small-checkbox-label" Value="@("Phone")">
                                                Peer
                                            </MudRadio>
                                            <MudRadio T="string" Class="small-checkbox-label" Value="@("Both")">
                                                Both
                                            </MudRadio>
                                        </MudRadioGroup>
                                    </MudItem>

                                    <MudItem xs="12" sm="6" Class="d-flex" Style="gap:12px; align-items:center;">
                                        <MudText Typo="Typo.body2">Best time to contact:</MudText>
