                                                      @bind-Value="referenceDetails.Ref1Email"
                                                      Required="true"
                                                      RequiredError="Email Contact Information is required"
                                                      Label="Email Contact Information" />
                                    </MudItem>

                                    <MudItem xs="12" sm="4">
                                        <MudTextField FullWidth="true"
                                                      Adornment="Adornment.Start"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense"
                                                      Class="oneplatform-rounded-input"
                                                      @bind-Value="referenceDetails.Ref1ContactNumber"
                                                      Required="true"
