                                                                          Adornment="Adornment.Start"
                                                                          Variant="Variant.Outlined"
                                                                          Margin="Margin.Dense"
                                                                          Class="oneplatform-rounded-input" />
                                                        </div>
                                                    </div>
                                                </MudItem>

                                                <MudItem xs="12">
                                                    <div style="display:flex; justify-content:center;">
                                                        <div style="width:40%;">
                                                            <MudDatePicker @bind-Date="SignatureDate"
