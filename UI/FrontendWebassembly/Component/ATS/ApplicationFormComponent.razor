@inject IATSService ATSService

<MudPaper Style="border-radius:20px; overflow:hidden; box-shadow:0px 10px 45px rgba(0,0,0,0.1); max-width:1200px; min-width:800px; min-height:600px; margin: 5px;">
    @if(!showPhilSys)
    {
        <MudStepper @ref="_stepper" @bind-ActiveIndex="_activeStep" Class="custom-stepper">
            <ChildContent>
                <!-- STEP 1 -->
                <MudStep Title="Part 1 - Step 1">
                    <MudPaper Style="margin:100px;" Elevation="0">
                        <MudGrid Justify="Justify.Center"
                                 AlignItems="AlignItems.Center">
                            <MudItem xs="12" sm="6" Class="d-flex justify-center align-content-center">
                            <MudPaper Elevation="0" Style="width: 100%;">
                                <div class="d-flex flex-column align-center text-center" style="height:100%; justify-content:center; padding:24px;">
                                    <MudText Typo="Typo.h5" Style="font-weight:700;" Class="gradient-text">Get your identity verified using your PSA's live national ID verification free of charge!</MudText>
                                    <div class="mt-4 d-flex" style="align-items:center; gap:16px; justify-content:center ">
                                        <MudImage Src="/images/ats/philippine-id.png" Alt="Philippine Identification System" Style="max-width:500px; height:auto;" />
                                    </div>
                                </div>
                            </MudPaper>
  
                            </MudItem>
                            <MudItem xs="12" sm="6" Class="d-flex justify-center align-center">
                                <div style="padding:18px;">
                                    <MudPaper Class="pa-4" Style="background:linear-gradient(180deg,#f2fbff,#e6f7fb); box-shadow: 0 0 10px rgba(42,119,174,0.8); width:100%; border-radius:8px;">
                                        <MudText Typo="Typo.subtitle1" Style="font-weight:700;" Class="mb-2 gradient-text">IMPORTANT NOTICE!</MudText>
                                        <MudText Typo="Typo.body2" Class="mb-3">
                                            I am a registered PSA National ID member and I voluntarily consent to share my verified information to any prospective employer I am applying for.
                                        </MudText>
                                        <div class="d-flex flex-column align-center justify-center mt-4">
                                            <MudCheckBox T="bool" @bind-Value="consent" Label=" Yes, I agree and wish to proceed." />
                                            <MudButton Disabled="!consent"
                                                       Class="@($"mb-4 theme-button {(consent ? "theme-button-active " : "theme-button-inactive")}")"
                                                       Style="width: 150px; border-radius: 4px;"
                                                       OnClick="ProceedClicked">
                                                Proceed
                                            </MudButton>

                                            <MudCheckBox T="bool"
                                                         @bind-Value="declineConsent"
                                                         Label="No, I do not wish to proceed." />
                                            <div class="d-flex" style="gap:30px;">
                                                <MudButton Style="background-color:gray; color:white; border-radius: 4px;" OnClick="SkipStep">Skip</MudButton>
                                                <MudButton Style="background-color:gray; color:white; border-radius: 4px;" OnClick="ResetStepper">Cancel</MudButton>
                                            </div>
                                        </div>
                                    </MudPaper>
                                </div>

                            </MudItem>
                        </MudGrid>
                    </MudPaper>
                    
                </MudStep>

                <!-- STEP 2 -->
                <MudStep Title="Part 1 - Step 2">
                    <MudText Typo="Typo.h6" Align="Align.Center" Style="font-weight:700;" Class="mb-4 mt-4 gradient-text">Personal Information</MudText>
                    <MudGrid>
                        <!-- Left column: Personal information fields -->
                        <MudItem xs="12" sm="6">
                            <MudPaper Class="pa-4" Elevation="0">
                                <MudGrid>
                                    <MudItem xs="12">
                                        <MudTextField FullWidth="true"
                                                      Adornment="Adornment.Start"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense"
                                                      @bind-Value="personalDetails.PositionAppliedFor"
                                                      Class="oneplatform-rounded-input"
                                                      Label="Position Applied For" />
                                    </MudItem>

                                    <MudItem xs="12">
                                        <MudTextField FullWidth="true"
                                                      Adornment="Adornment.Start"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense"
                                                      @bind-Value="personalDetails.FirstName"
                                                      Class="oneplatform-rounded-input"
                                                      Label="First Name" />
                                    </MudItem>
                                    <MudItem xs="12" sm="6">
                                        <MudTextField FullWidth="true"
                                                      Adornment="Adornment.Start"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense"
                                                      @bind-Value="personalDetails.MiddleName"
                                                      Class="oneplatform-rounded-input"
                                                      Label="Middle Name" />
                                    </MudItem>
                                    <MudItem xs="12" sm="6" Class="d-flex align-center">
                                        <div style="display:flex; align-items:center; gap:8px; width:100%;">
                                            <MudCheckBox T="bool"
                                                         @bind-Checked="NoMiddleName"
                                                         Label="Check if no Middle Name"
                                                         Class="small-checkbox-label" />
                                        </div>
                                    </MudItem>

                                    <MudItem xs="12">
                                        <MudTextField FullWidth="true"
                                                      Adornment="Adornment.Start"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense"
                                                      @bind-Value="personalDetails.LastName"
                                                      Class="oneplatform-rounded-input"
                                                      Label="Last Name" />
                                    </MudItem>
                                    <MudItem xs="12" sm="4">
                                        <MudTextField FullWidth="true"
                                                      Adornment="Adornment.Start"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense"
                                                      @bind-Value="personalDetails.Suffix"
                                                      Class="oneplatform-rounded-input"
                                                      Label="Suffix" />
                                    </MudItem>
                                    <MudItem xs="12" sm="4">
                                        <MudDatePicker @bind-Date="DateOfBirth"
                                                       Label="Birth Date"
                                                       Adornment="Adornment.End"
                                                       Required="true"
                                                       RequiredError="Birth Date is required"
                                                       Variant="Variant.Outlined"
                                                       Margin="Margin.Dense"
                                                       DateFormat="MM/dd/yyyy"
                                                       Class="oneplatform-rounded-input" />
                                    </MudItem>

                                    <MudItem xs="12" sm="4">
                                        <MudSelect T="string"
                                                   @bind-Value="personalDetails.Sex"
                                                   Class="oneplatform-rounded-input"
                                                   Adornment="Adornment.Start"
                                                   Variant="Variant.Outlined"
                                                   Margin="Margin.Dense"
                                                   Label="Sex"
                                                   FullWidth="true">
                                            <MudSelectItem Value="@("Male")">Male</MudSelectItem>
                                            <MudSelectItem Value="@("Female")">Female</MudSelectItem>
                                            <MudSelectItem Value="@("Prefer not to say")">Prefer not to say</MudSelectItem>
                                        </MudSelect>
                                    </MudItem>

                                    <MudItem xs="12">
                                        <MudTextField FullWidth="true"
                                                      Adornment="Adornment.Start"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense"
                                                      @bind-Value="personalDetails.EmailAlternative"
                                                      Class="oneplatform-rounded-input"
                                                      Label="Alternate Email Address" />
                                    </MudItem>

                                    <MudItem xs="12">
                                        <MudTextField FullWidth="true"
                                                      Adornment="Adornment.Start"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense"
                                                      @bind-Value="personalDetails.MobileNumber"
                                                      Class="oneplatform-rounded-input"
                                                      Label="Phone Number" />
                                    </MudItem>
                                </MudGrid>
                            </MudPaper>
                        </MudItem>

                        <MudItem xs="12" sm="6">
                            <MudPaper Class="pa-10" Elevation="0" Style=" height: auto; background:linear-gradient(180deg,#f2fbff,#e6f7fb); box-shadow: 0 0 10px rgba(42,119,174,0.8); width:100%; border-radius:8px;">
                                <div class="d-flex flex-column align-center" style="gap:12px;">
                                    <MudImage Src="images/generic/default_picture.jpg"
                                              Alt="User Profile"
                                              Style="height: 200px; width: 200px; object-fit: cover; border-radius: 50%; outline: 2px solid #000;" />
                                    <MudText Typo="Typo.subtitle1">Biometric Image</MudText>

                                    <div class="d-flex flex-column" style="width:100%; margin-top:12px; gap:8px;">
                                        <MudFileUpload @ref="@GovernmentUploadIdFile"
                                                       T="IBrowserFile"
                                                       @bind-Files="personalDetails.AdditionalGovtIDFile"
                                                       Accept=".xls,.xlsx,.csv"
                                                       DragAndDrop="true">
                                            <CustomContent>
                                                <div style="display: flex; justify-content: center;">
                                                    <MudFab Class="oneplatform-rounded-input"
                                                            StartIcon="@Icons.Material.Filled.CloudUpload"
                                                            Style="width:300px; border: 1px solid gray; border-radius: 4px;"
                                                            OnClick="@context.OpenFilePickerAsync"
                                                            Label="Upload Unexpired Government ID" />
                                                </div>
                                            </CustomContent>
                                            <SelectedTemplate>
                                                @if (context != null)
                                                {
                                                    <div style="display:flex; justify-content:center; width:100%; margin-top:8px;">
                                                        <MudStack Row AlignItems="AlignItems.Center" Spacing="2" Class="w-70">
                                                            <MudText>@context.Name (@($"{context.Size / 1024d:N1} kB"))</MudText>
                                                            <MudIconButton Icon="@Icons.Material.Filled.Close"
                                                                           Color="Color.Default"
                                                                           Size="Size.Small"
                                                                           aria-label="Remove file"
                                                                           OnClick="@(() => RemoveFileFromUploadsAsync(context))" />
                                                        </MudStack>
                                                    </div>
                                                }
                                            </SelectedTemplate>
                                        </MudFileUpload>

                                        <MudFileUpload T="IBrowserFile" @ref="@NBIClearanceUploadFile"
                                                       @bind-File="personalDetails.NBIClearanceFile"
                                                       Accept=".xls,.xlsx,.csv"
                                                       DragAndDrop="true"
                                                       Class="mt-4">
                                            <CustomContent>
                                                <div style="display: flex; justify-content: center;">
                                                    <MudFab Class="oneplatform-rounded-input"
                                                            StartIcon="@Icons.Material.Filled.CloudUpload"
                                                            Style="width:300px; border: 1px solid gray; border-radius: 4px;"
                                                            OnClick="@context.OpenFilePickerAsync"
                                                            Label="Upload NBI Clearance" />
                                                </div>
                                            </CustomContent>
                                            <SelectedTemplate>
                                                @if (context != null)
                                                {
                                                    <div style="display:flex; justify-content:center; width:100%; margin-top:8px;">
                                                        <MudStack Row AlignItems="AlignItems.Center" Spacing="2" Class="w-70">
                                                            <MudText>@context.Name (@($"{context.Size / 1024d:N1} kB"))</MudText>
                                                            <MudIconButton Icon="@Icons.Material.Filled.Close"
                                                                           Color="Color.Default"
                                                                           Size="Size.Small"
                                                                           aria-label="Remove file"
                                                                           OnClick="@(() => RemoveFileFromUploadsAsync(context))" />
                                                        </MudStack>
                                                    </div>
                                                }
                                            </SelectedTemplate>
                                        </MudFileUpload>

                                        <MudFileUpload T="IBrowserFile" @ref="@CVOrResumeUploadFile"
                                                       @bind-File="personalDetails.ResumeFile"
                                                       Accept=".xls,.xlsx,.csv"
                                                       DragAndDrop="true"
                                                       Class="mt-4">
                                            <CustomContent>
                                                <div style="display: flex; justify-content: center;">
                                                    <MudFab Class="oneplatform-rounded-input"
                                                            StartIcon="@Icons.Material.Filled.CloudUpload"
                                                            Style="width:300px; border: 1px solid gray; border-radius: 4px;"
                                                            OnClick="@context.OpenFilePickerAsync"
                                                            Label="Upload CV / Resume" />
                                                </div>
                                            </CustomContent>
                                            <SelectedTemplate>
                                                @if (context != null)
                                                {
                                                    <div style="display:flex; justify-content:center; width:100%; margin-top:8px;">
                                                        <MudStack Row AlignItems="AlignItems.Center" Spacing="2" Class="w-70">
                                                            <MudText>@context.Name (@($"{context.Size / 1024d:N1} kB"))</MudText>
                                                            <MudIconButton Icon="@Icons.Material.Filled.Close"
                                                                           Color="Color.Default"
                                                                           Size="Size.Small"
                                                                           aria-label="Remove file"
                                                                           OnClick="@(() => RemoveFileFromUploadsAsync(context))" />
                                                        </MudStack>
                                                    </div>
                                                }
                                            </SelectedTemplate>
                                        </MudFileUpload>
                                    </div>
                                </div>
                            </MudPaper>
                        </MudItem>
                    </MudGrid>
                </MudStep>

                <!-- STEP 3 -->
                <MudStep Title="Part 1 - Step 3">
                    <MudText Typo="Typo.h6" Align="Align.Center" Style="font-weight:700;" Class="mb-4 mt-4 gradient-text">Address</MudText>
                    <MudGrid>
                        <!-- Address section -->
                        <MudItem xs="12" sm="4">
                            <MudTextField FullWidth="true"
                                          Adornment="Adornment.Start"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Class="oneplatform-rounded-input"
                                          @bind-Value="addressDetails.CurrentAddress"
                                          Label="Current Address (No., Street, Village, Brgy.)" />
                        </MudItem>
                        <MudItem xs="12" sm="2">
                            <MudTextField FullWidth="true"
                                          Adornment="Adornment.Start"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Class="oneplatform-rounded-input"
                                          @bind-Value="addressDetails.CurrentCity"
                                          Label="City" />
                        </MudItem>
                        <MudItem xs="12" sm="2">
                            <MudTextField FullWidth="true"
                                          Adornment="Adornment.Start"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Class="oneplatform-rounded-input"
                                          @bind-Value="addressDetails.CurrentProvince"
                                          Label="State / Province / Region" />
                        </MudItem>
                        <MudItem xs="12" sm="2">
                            <MudTextField FullWidth="true"
                                          Adornment="Adornment.Start"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Class="oneplatform-rounded-input"
                                          @bind-Value="addressDetails.CurrentCountry"
                                          Label="Country" />
                        </MudItem>
                        <MudItem xs="12" sm="2">
                            <MudTextField FullWidth="true"
                                          Adornment="Adornment.Start"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Class="oneplatform-rounded-input"
                                          @bind-Value="addressDetails.CurrentPostalCode"
                                          Label="Zip / Postal Code" />
                        </MudItem>

                        <MudItem xs="12" Style="margin-bottom:-10px;">
                            <MudCheckBox T="bool" 
                                         Class="small-checkbox-label" 
                                         Style="margin-bottom:-12px;" 
                                         Checked="SameAsPermanent"
                                         CheckedChanged="OnSameAsPermanentChanged" 
                                         Label="Check if current address is the same as permanent address" />
                        </MudItem>

                        <MudItem xs="12" sm="4">
                            <MudTextField FullWidth="true"
                                          Adornment="Adornment.Start"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Class="oneplatform-rounded-input"
                                          @bind-Value="addressDetails.PermanentAddress"
                                          Label="Permanent Address (No., Street, Village, Brgy.)" />
                        </MudItem>
                        <MudItem xs="12" sm="2">
                            <MudTextField FullWidth="true"
                                          Adornment="Adornment.Start"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Class="oneplatform-rounded-input"
                                          @bind-Value="addressDetails.PermanentCity"
                                          Label="City" />
                        </MudItem>
                        <MudItem xs="12" sm="2">
                            <MudTextField FullWidth="true"
                                          Adornment="Adornment.Start"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Class="oneplatform-rounded-input"
                                          @bind-Value="addressDetails.PermanentProvince"
                                          Label="State / Province / Region" />
                        </MudItem>
                        <MudItem xs="12" sm="2">
                            <MudTextField FullWidth="true"
                                          Adornment="Adornment.Start"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Class="oneplatform-rounded-input"
                                          @bind-Value="addressDetails.PermanentCountry"
                                          Label="Country" />
                        </MudItem>
                        <MudItem xs="12" sm="2">
                            <MudTextField FullWidth="true"
                                          Adornment="Adornment.Start"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Class="oneplatform-rounded-input"
                                          @bind-Value="addressDetails.PermanentPostalCode"
                                          Label="Zip / Postal Code" />
                        </MudItem>

                        <!-- Ownership -->
                        <MudItem xs="12">
                            <MudText Typo="Typo.subtitle1" Align="Align.Left">Type of Ownership</MudText>
                            <div class="d-flex" style="gap:12px; flex-wrap:wrap;">
                                <MudRadioGroup T="string"
                                               @bind-Value="addressDetails.TypeOfOwnership"
                                               Class="d-flex flex-wrap"
                                               Style="gap:12px;">

                                    <MudRadio T="string" Class="small-checkbox-label" Value="@("Owned")">
                                        Owned
                                    </MudRadio>
                                    <MudRadio T="string" Class="small-checkbox-label" Value="@("Rent")">
                                        Rent
                                    </MudRadio>
                                    <MudRadio T="string" Class="small-checkbox-label" Value="@("Living with family / relatives")">
                                        Living with family / relatives
                                    </MudRadio>
                                    <MudRadio T="string" Class="small-checkbox-label" Value="@("Others")">
                                        Others
                                    </MudRadio>
                                    @if (addressDetails.TypeOfOwnership == "Others")
                                    {
                                        <MudTextField Adornment="Adornment.Start"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense"
                                                      Style="width:200px;"
                                                      Class="oneplatform-rounded-input ml-2"
                                                      @bind-Value="OwnershipOtherText"
                                                      Label="Please specify" />
                                    }
                                </MudRadioGroup>
                            </div>
                        </MudItem>

                        <!-- Educational Background -->
                        <MudItem xs="12">
                            <MudText Typo="Typo.h6" Class="gradient-text" Style="font-weight:700;" Align="Align.Center">Educational Background</MudText>
                        </MudItem>

                        <MudItem xs="12" sm="6">
                            <MudSelect T="string"
                                        @bind-Value="educationalBackground.HighestEducationalAttainment"
                                        Class="oneplatform-rounded-input"
                                        Adornment="Adornment.Start"
                                        Variant="Variant.Outlined"
                                        Margin="Margin.Dense"
                                        Label="Highest Educational Attainment"
                                        FullWidth="true">
                                <MudSelectItem Value="@("None")">None</MudSelectItem>
                                <MudSelectItem Value="@("Elementary Graduate")">Elementary Graduate</MudSelectItem>
                                <MudSelectItem Value="@("High School Graduate")">High School Graduate</MudSelectItem>
                                <MudSelectItem Value="@("Senior High School Graduate")">Senior High School Graduate</MudSelectItem>
                                <MudSelectItem Value="@("College Graduate")">College Graduate</MudSelectItem>
                                <MudSelectItem Value="@("Master's Graduate")">Master's Graduate</MudSelectItem>
                                <MudSelectItem Value="@("Doctorate Graduate")">Doctorate Graduate</MudSelectItem>
                            </MudSelect>
                        </MudItem>

                        <MudItem xs="12" sm="3">
                            <MudDatePicker Label="Graduation Date"
                                           Adornment="Adornment.End"
                                           Required="true"
                                           Variant="Variant.Outlined"
                                           Margin="Margin.Dense"
                                           Class="oneplatform-rounded-input"
                                           @bind-Date="GraduationDate"
                                           DateFormat="MM/dd/yyyy" />
                        </MudItem>

                        <MudItem xs="12" sm="6">
                            <MudTextField FullWidth="true"
                                          Adornment="Adornment.Start"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Class="oneplatform-rounded-input"
                                          @bind-Value="DegreeWithMajor"
                                          Label="Degree with major" />
                        </MudItem>

                        <MudItem xs="12" sm="6">
                            <MudFileUpload T="IBrowserFile" @ref="@DiplomaORTORUploadFile"
                                           @bind-File="DiplomaORTORFile"
                                           Accept=".xls,.xlsx,.csv"
                                           DragAndDrop="true">
                                <CustomContent>
                                    <MudFab Class="oneplatform-rounded-input"
                                            StartIcon="@Icons.Material.Filled.CloudUpload"
                                            Style="border: 1px solid gray; border-radius: 4px; width: 270px;"
                                            OnClick="@context.OpenFilePickerAsync"
                                            Label="Upload Diploma / TOR" />
                                </CustomContent>
                                <SelectedTemplate>
                                    @if (context != null)
                                    {
                                        <div style="display:flex; justify-content:center; width:100%; margin-top:8px;">
                                            <MudStack Row AlignItems="AlignItems.Center" Spacing="2" Class="w-70">
                                                <MudText>@context.Name (@($"{context.Size / 1024d:N1} kB"))</MudText>
                                                <MudIconButton Icon="@Icons.Material.Filled.Close"
                                                               Color="Color.Default"
                                                               Size="Size.Small"
                                                               aria-label="Remove file"
                                                               OnClick="@(() => RemoveFileFromUploadsAsync(context))" />
                                            </MudStack>
                                        </div>
                                    }
                                </SelectedTemplate>
                            </MudFileUpload>
                        </MudItem>

                        <MudItem xs="12" sm="6">
                            <MudTextField FullWidth="true"
                                          Adornment="Adornment.Start"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Class="oneplatform-rounded-input"
                                          @bind-Value="AcademicInstitution"
                                          Label="Academic Institution" />
                        </MudItem>
                    </MudGrid>
                </MudStep>

                <!-- STEP 4 -->
                <MudStep Title="Part 1 - Step 4">
                    <MudText Typo="Typo.h6" Style="font-weight:700;" Align="Align.Center" Class="mt-4 mb-4 gradient-text">Credentials &amp; Licenses</MudText>
                    <MudGrid>
                        <MudItem xs="12" sm="8">
                            <MudTextField FullWidth="true"
                                          Adornment="Adornment.Start"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Class="oneplatform-rounded-input"
                                          @bind-Value="licensesDetails.LicenseName"
                                          Label="Professional License" />
                        </MudItem>

                        <MudItem xs="12" sm="4">
                            <MudDatePicker Adornment="Adornment.End"
                                           Required="true"
                                           Variant="Variant.Outlined"
                                           Margin="Margin.Dense"
                                           Class="oneplatform-rounded-input"
                                           @bind-Date="LicenseExpiryDate"
                                           Label="License Expiry Date"
                                           DateFormat="MM/dd/yyyy" />
                        </MudItem>

                        <MudItem xs="12" sm="8">
                            <MudTextField FullWidth="true"
                                          Adornment="Adornment.Start"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Class="oneplatform-rounded-input"
                                          @bind-Value="licensesDetails.LicenseNumber"
                                          Label="License No." />
                        </MudItem>

                        <MudItem xs="12" sm="4">
                            <MudFileUpload T="IBrowserFile" @ref="@ProfessionalLicenseUploadFile"
                                           @bind-File="licensesDetails.LicenseUploadFile"
                                           Accept=".xls,.xlsx,.csv"
                                           DragAndDrop="true">
                                <CustomContent>
                                    <MudFab Class="oneplatform-rounded-input"
                                            StartIcon="@Icons.Material.Filled.CloudUpload"
                                            Style="border: 1px solid gray; border-radius: 4px; width: 368px;"
                                            OnClick="@context.OpenFilePickerAsync"
                                            Label="Upload Professional License" />
                                </CustomContent>
                                <SelectedTemplate>
                                    @if (context != null)
                                    {
                                        <div style="display:flex; justify-content:center; width:100%; margin-top:8px;">
                                            <MudStack Row AlignItems="AlignItems.Center" Spacing="2" Class="w-70">
                                                <MudText>@context.Name (@($"{context.Size / 1024d:N1} kB"))</MudText>
                                                <MudIconButton Icon="@Icons.Material.Filled.Close"
                                                               Color="Color.Default"
                                                               Size="Size.Small"
                                                               aria-label="Remove file"
                                                               OnClick="@(() => RemoveFileFromUploadsAsync(context))" />
                                            </MudStack>
                                        </div>
                                    }
                                </SelectedTemplate>
                            </MudFileUpload>
                        </MudItem>

                        <MudItem xs="12">
                            <MudText Typo="Typo.h6" Class="gradient-text" Style="font-weight:700;" Align="Align.Center">Professional Experiences</MudText>
                        </MudItem>

                        <MudItem xs="12" sm="6">
                            <MudTextField FullWidth="true"
                                          Adornment="Adornment.Start"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Class="oneplatform-rounded-input"
                                          @bind-Value="professionalExperiences.Emp1CompanyName"
                                          Label="Company Name" />
                        </MudItem>

