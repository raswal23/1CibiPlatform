                                        </MudPaper>
                                    </MudItem>
                                </MudGrid>
                            </MudItem>
                        </MudGrid>
                    </MudStep>
                </ChildContent>

                <ActionContent Context="stepper">
                    @if (_activeStep != 0)
                    {
                        <div class="d-flex justify-space-between w-100 pa-2">

                            <MudButton Style="width: 150px; border-radius: 4px; border: 2px solid gray;"
                                       Class="mt-3 mb-4"
                                       OnClick="@(() => stepper.PreviousStepAsync())">
                                Previous
                            </MudButton>

                            @if (_activeStep == stepper.Steps.Count - 1)
                            {
                                <MudButton Class="theme-button mt-3 theme-button-active mb-4"
                                           Style="width: 150px; border-radius: 4px; "
                                           OnClick="OnSubmitForm">

                                    @if (isSaving)
                                    {
                                        <MudProgressCircular Size="Size.Small" Indeterminate="true" />

                                        <span> Saving...</span>
                                    }
                                    else
                                    {
                                        <span>Submit</span>
                                    }
                                    
                                </MudButton>
                            }
                            else
                            {
                                <MudButton Class="theme-button mt-3 theme-button-active mb-4"
                                           Style="width: 150px; border-radius: 4px; "
                                           OnClick="OnSaveAndNextAsync">
                                    Save & Next
                                </MudButton>
                            }
                        </div>
                    }
                </ActionContent>
            </MudStepper>
        </MudForm>
    }

</MudPaper>
