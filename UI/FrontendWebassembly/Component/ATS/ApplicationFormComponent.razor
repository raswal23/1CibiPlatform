<MudPaper Style="border-radius:20px; overflow:hidden; box-shadow:0px 10px 45px rgba(0,0,0,0.1); max-width:1200px; margin: 5px;">
    @using Microsoft.AspNetCore.Components.Forms
    <MudStepper @ref="_stepper" ShowResetButton>
        <!-- STEP 1 -->
        <MudStep Title="Part 1 - Step 1">
            <MudGrid>
                <!-- Left column: heading and PSA image -->
                <MudItem xs="12" sm="7" Class="d-flex justify-center align-center">
                    <div class="d-flex flex-column align-center text-center" style="height:100%; justify-content:center; padding:24px;">
                        <MudText Typo="Typo.h5" Color="Color.Primary">Get your identity verified using your PSA's live national ID verification free of charge!</MudText>
                        <div class="mt-4 d-flex" style="align-items:center; gap:16px;  justify-center ">
                            <MudImage Src="/images/ats/philippine-id.png" Alt="Philippine Identification System" Style="max-width:280px; height:auto;" />
                        </div>
                    </div>
                </MudItem>

                <!-- Right column: important notice card -->
                <MudItem xs="12" sm="5">
                    <div style="height:100%; display:flex; align-items:center; padding:18px;">
                        <MudPaper Class="pa-4" Style="background:linear-gradient(180deg,#f2fbff,#e6f7fb); width:100%; border-radius:8px;">
                            <MudText Typo="Typo.subtitle2" Color="Color.Primary" Class="mb-2">IMPORTANT NOTICE!</MudText>
                            <MudText Typo="Typo.body2" Class="mb-3">
                                I am a registered PSA National ID member and I voluntarily consent to share my verified information to any prospective employer I am applying for.
                            </MudText>

                            <div class="d-flex flex-column align-center justify-center mt-4">
                                <MudCheckBox T="bool"
                                             @bind-Checked="consent"
                                             Label="Yes, I agree and wish to proceed." />
                                <MudButton Class="theme-button theme-button-active mb-4
                                           Disabled="!consent"
                                            OnClick="ProceedClicked">
                                    Proceed
                                </MudButton>

                                <MudCheckBox T="bool" 
                                             @bind-Checked="declineConsent" 
                                             Label="No, I do not wish to proceed." />
                                <div class="d-flex" style="gap:30px;">
                                    <MudButton Style="background-color:gray; color:white; border-radius: 4px;" OnClick="SkipStep">Skip</MudButton>
                                    <MudButton Style="background-color:gray; color:white; border-radius: 4px;" OnClick="ResetStepper">Cancel</MudButton>
                                </div>
                            </div>
                        </MudPaper>
                    </div>
                </MudItem>
            </MudGrid>
        </MudStep>


        <!-- STEP 2 -->
        <MudStep Title="Part 1 - Step 2">
            <MudGrid>
                <!-- Left column: Personal information fields -->
                <MudItem xs="12" sm="7">
                    <MudPaper Class="pa-4" Style="background:transparent;">
                        <MudText Typo="Typo.subtitle1" Align="Align.Center" Class="mb-4">Personal Information</MudText>
                        <MudGrid>
                            <MudItem xs="12">
                                <MudTextField @bind-Value="PositionAppliedFor" Placeholder="Position Applied For" FullWidth="true" />
                            </MudItem>

                            <MudItem xs="12" sm="4">
                                <MudTextField @bind-Value="FirstName" Placeholder="First Name*" FullWidth="true" />
                            </MudItem>
                            <MudItem xs="12" sm="4">
                                <MudTextField @bind-Value="MiddleName" Placeholder="Middle Name" FullWidth="true" />
                            </MudItem>
                            <MudItem xs="12" sm="4" Class="d-flex align-center">
                                <div style="display:flex; align-items:center; gap:8px; width:100%;">
                                    <MudCheckBox T="bool" @bind-Checked="NoMiddleName" Label="Check if no Middle Name" />
                                </div>
                            </MudItem>

                            <MudItem xs="12" sm="6">
                                <MudTextField @bind-Value="LastName" Placeholder="Last Name*" FullWidth="true" />
                            </MudItem>
                            <MudItem xs="12" sm="3">
                                <MudTextField @bind-Value="Suffix" Placeholder="Suffix" FullWidth="true" />
                            </MudItem>
                            <MudItem xs="12" sm="3">
                                <MudDatePicker @bind-Date="DateOfBirth" Placeholder="Date of Birth" DateFormat="MM/dd/yyyy" Class="w-100" />
                            </MudItem>

                            <MudItem xs="12" sm="3">
                                <MudSelect T="string" @bind-Value="Sex" Placeholder="Sex*" FullWidth="true">
                                    <MudSelectItem Value="@("Male")">Male</MudSelectItem>
                                    <MudSelectItem Value="@("Female")">Female</MudSelectItem>
                                    <MudSelectItem Value="@("Prefer not to say")">Prefer not to say</MudSelectItem>
                                </MudSelect>
                            </MudItem>

                            <MudItem xs="12">
                                <MudTextField @bind-Value="AlternateEmail" Placeholder="Alternate Email Address*" FullWidth="true" />
                            </MudItem>

                            <MudItem xs="12">
                                <MudTextField @bind-Value="PhoneNumber" Placeholder="Phone Number*" FullWidth="true" />
                            </MudItem>
                        </MudGrid>
                    </MudPaper>
                </MudItem>

                <!-- Right column: biometric image and uploads -->
                <MudItem xs="12" sm="5">
                    <div style="display:flex; align-items:center; height:100%;">
                        <MudPaper Class="pa-4" Style="width:100%; border-radius:8px; background:linear-gradient(180deg,#ffffff,#f6fbff);">
                            <div class="d-flex flex-column align-center" style="gap:12px;">
                                <MudAvatar Size="Size.Large" Icon="Icons.Material.Filled.Person" Class="mb-2" />
                                <MudText Typo="Typo.caption">Biometric Image</MudText>

                                <InputFile OnChange="OnBiometricUpload" />

                                <div class="d-flex flex-column" style="width:100%; margin-top:12px; gap:8px;">
                                    <InputFile OnChange="OnGovtIdUpload" />
                                    <MudText Typo="Typo.caption">Upload Unexpired Govt Issued ID</MudText>

                                    <InputFile OnChange="OnNbiUpload" />
                                    <MudText Typo="Typo.caption">Upload NBI Clearance</MudText>

                                    <InputFile OnChange="OnCvUpload" />
                                    <MudText Typo="Typo.caption">Upload CV / Resume</MudText>
                                </div>

                                <div class="d-flex justify-end mt-6">
                                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveAndNextAsync">Save & Next</MudButton>
                                </div>
                            </div>
                        </MudPaper>
                    </div>
                </MudItem>
            </MudGrid>
        </MudStep>

        <!-- STEP 3 -->
        <MudStep Title="Part 1 - Step 3">
            <MudGrid>
                <!-- Address section -->
                <MudItem xs="12">
                    <MudText Typo="Typo.subtitle1" Align="Align.Center" Class="mb-4">Current Address</MudText>
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="CurrentAddressLine" Placeholder="Current Address (No., Street, Village, Brgy.)*" FullWidth="true" />
                </MudItem>
                <MudItem xs="12" sm="2">
                    <MudTextField @bind-Value="CurrentCity" Placeholder="City*" FullWidth="true" />
                </MudItem>
                <MudItem xs="12" sm="2">
                    <MudTextField @bind-Value="CurrentState" Placeholder="State / Province / Region*" FullWidth="true" />
                </MudItem>
                <MudItem xs="6" sm="1">
                    <MudTextField @bind-Value="CurrentCountry" Placeholder="Country*" FullWidth="true" />
                </MudItem>
                <MudItem xs="6" sm="1">
                    <MudTextField @bind-Value="CurrentZip" Placeholder="Zip / Postal Code*" FullWidth="true" />
                </MudItem>

                <MudItem xs="12" Class="d-flex align-center">
                    <MudCheckBox T="bool" @bind-Checked="SameAsPermanent" Label="Check if current address is the same as permanent address"/>
                </MudItem>

                <MudItem xs="12">
                    <MudText Typo="Typo.subtitle1" Align="Align.Center" Class="mb-4">Permanent Address</MudText>
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="PermanentAddressLine" Placeholder="Permanent Address (No., Street, Village, Brgy.)*" FullWidth="true" />
                </MudItem>
                <MudItem xs="12" sm="2">
                    <MudTextField @bind-Value="PermanentCity" Placeholder="City*" FullWidth="true" />
                </MudItem>
                <MudItem xs="12" sm="2">
                    <MudTextField @bind-Value="PermanentState" Placeholder="State / Province / Region*" FullWidth="true" />
                </MudItem>
                <MudItem xs="6" sm="1">
                    <MudTextField @bind-Value="PermanentCountry" Placeholder="Country*" FullWidth="true" />
                </MudItem>
                <MudItem xs="6" sm="1">
                    <MudTextField @bind-Value="PermanentZip" Placeholder="Zip / Postal Code*" FullWidth="true" />
                </MudItem>

                <!-- Ownership -->
                <MudItem xs="12" Class="mt-3">
                    <MudText Typo="Typo.subtitle1" Align="Align.Left" Class="mb-2">Type of Ownership*</MudText>
                    <div class="d-flex" style="gap:12px; flex-wrap:wrap;">
                        <MudCheckBox T="bool" @bind-Checked="OwnershipOwned" Label="Owned" />
                        <MudCheckBox T="bool" bind-Checked="OwnershipRent" Label="Rent" />
                        <MudCheckBox T="bool" @bind-Checked="OwnershipLivingWithFamily" Label="Living with family / relatives" />
                        <MudCheckBox T="bool" @bind-Checked="OwnershipOthers" Label="Others" />
                        @if (OwnershipOthers)
                        {
                            <MudTextField @bind-Value="OwnershipOtherText" Placeholder="Please specify" />
                        }
                    </div>
                </MudItem>

                <!-- Educational Background -->
                <MudItem xs="12" Class="mt-6">
                    <MudText Typo="Typo.subtitle1" Align="Align.Center" Class="mb-4">Educational Background</MudText>
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="HighestEducationalAttainment" Placeholder="Highest Educational Attainment*" FullWidth="true" />
                </MudItem>
                <MudItem xs="12" sm="3">
                    <MudDatePicker @bind-Date="GraduationDate" Placeholder="Graduation Date" DateFormat="MM/dd/yyyy" Class="w-100" />
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="DegreeWithMajor" Placeholder="Degree with major*" FullWidth="true" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="AcademicInstitution" Placeholder="Academic Institution*" FullWidth="true" />
                </MudItem>

                <MudItem xs="12" Class="mt-3">
                    <MudText Typo="Typo.caption">Upload Diploma / TOR</MudText>
                    <InputFile OnChange="OnDiplomaUpload" />
                </MudItem>

                <MudItem xs="12" Class="d-flex justify-end mt-6">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveAndNextAsync">Save & Next</MudButton>
                </MudItem>
            </MudGrid>
        </MudStep>

        <!-- STEP 4 -->
        <MudStep Title="Part 1 - Step 4">
            <MudGrid>
                <MudItem xs="12">
                    <MudText Typo="Typo.subtitle1" Align="Align.Center" Class="mb-4">Credentials &amp; Licenses</MudText>
                </MudItem>

                <MudItem xs="12" sm="8">
                    <MudTextField @bind-Value="ProfessionalLicense" Placeholder="Professional License*" FullWidth="true" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudDatePicker @bind-Date="LicenseExpiryDate" Placeholder="License Expiry Date" DateFormat="MM/dd/yyyy" Class="w-100" />
                </MudItem>

                <MudItem xs="12">
                    <MudTextField @bind-Value="LicenseNumber" Placeholder="License No.*" FullWidth="true" />
                </MudItem>

                <MudItem xs="12" Class="mb-4">
                    <MudText Typo="Typo.caption">Upload Professional License</MudText>
                    <InputFile OnChange="OnProfessionalLicenseUpload" />
                </MudItem>

                <MudItem xs="12" Class="mt-4">
                    <MudText Typo="Typo.subtitle1" Align="Align.Center" Class="mb-4">Professional Experiences</MudText>
                </MudItem>

                <MudItem xs="12">
                    <MudTextField @bind-Value="CompanyName" Placeholder="Company Name*" FullWidth="true" />
                </MudItem>

                <MudItem xs="12" Class="d-flex" Style="gap:12px;">
                    <MudCheckBox T="bool" @bind-Checked="CurrentlyEmployed" Label="Currently Employed?" />
                    <MudCheckBox T="bool" @bind-Checked="WithPermissionToContact" Label="With permission to contact?" />
                </MudItem>

                <MudItem xs="12" sm="4">
                    <MudTextField @bind-Value="CompanyCity" Placeholder="Company City / Address" FullWidth="true" />
                </MudItem>
                <MudItem xs="12" sm="3">
                    <MudTextField @bind-Value="CompanyState" Placeholder="State / Province / Region" FullWidth="true" />
                </MudItem>
                <MudItem xs="6" sm="2">
                    <MudTextField @bind-Value="CompanyCountry" Placeholder="Country" FullWidth="true" />
                </MudItem>
                <MudItem xs="6" sm="1">
                    <MudTextField @bind-Value="CompanyZip" Placeholder="Zip / Postal Code" FullWidth="true" />
                </MudItem>
                <MudItem xs="12" sm="2">
                    <MudDatePicker @bind-Date="DatePermittedToContact" Placeholder="Date permitted to contact" DateFormat="MM/dd/yyyy" Class="w-100" />
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="JobTitle" Placeholder="Job Title*" FullWidth="true" />
                </MudItem>
                <MudItem xs="12" sm="3">
                    <MudDatePicker @bind-Date="StartOfEmployment" Placeholder="Start Date of Employment" DateFormat="MM/dd/yyyy" Class="w-100" />
                </MudItem>
                <MudItem xs="12" sm="3">
                    <MudDatePicker @bind-Date="EndOfEmployment" Placeholder="End Date of Employment" DateFormat="MM/dd/yyyy" Class="w-100" />
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="SupervisorName" Placeholder="Supervisor Name*" FullWidth="true" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="ContactInformation" Placeholder="Contact Information*" FullWidth="true" />
                </MudItem>

                <MudItem xs="12" Class="mt-2">
                    <MudText Typo="Typo.caption">Upload COE/ID</MudText>
                    <InputFile OnChange="OnCoeUpload" />
                </MudItem>

                <MudItem xs="12" Class="d-flex align-center" Style="gap:12px; margin-top:12px;">
                    <MudText Typo="Typo.body2">Add another employer?</MudText>
                    <MudCheckBox T="bool" @bind-Checked="AddAnotherEmployer" />
                </MudItem>

                <MudItem xs="12" Class="d-flex justify-end mt-6">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveAndNextAsync">Save & Next</MudButton>
                </MudItem>
            </MudGrid>
        </MudStep>

         <!-- STEP 5 -->
        <MudStep Title="Part 1 - Step 5">
            <MudGrid>
                <MudItem xs="12">
                    <MudText Typo="Typo.subtitle1" Align="Align.Center" Class="mb-4">Professional Character Reference</MudText>
                </MudItem>

                <!-- Reference 1 -->
                <MudItem xs="12" Class="mb-2">
                    <MudGrid>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="Reference1FullName" Placeholder="Full Name of Reference #1*" FullWidth="true" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <div class="d-flex" style="gap:8px; align-items:center;">
                                <MudText Typo="Typo.body2">Professional Relationship*</MudText>
                                <MudCheckBox T="bool" @bind-Checked="Ref1Colleague" Label="Colleague" />
                                <MudCheckBox T="bool" @bind-Checked="Ref1Superior" Label="Superior" />
                                <MudCheckBox T="bool" @bind-Checked="Ref1Peer" Label="Peer" />
                                <MudCheckBox T="bool" @bind-Checked="Ref1Subordinate" Label="Subordinate" />
                            </div>
                        </MudItem>

                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="Reference1Company" Placeholder="Affiliated Company*" FullWidth="true" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="Reference1Email" Placeholder="Email Contact Information*" FullWidth="true" />
                        </MudItem>

                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="Reference1Mobile" Placeholder="Mobile Contact Information*" FullWidth="true" />
                        </MudItem>

                        <MudItem xs="12" sm="6" Class="d-flex" Style="gap:12px; align-items:center;">
                            <MudText Typo="Typo.body2">Available to reach on:</MudText>
                            <MudCheckBox T="bool" @bind-Checked="Ref1AvailableEmail" Label="Email" />
                            <MudCheckBox T="bool" @bind-Checked="Ref1AvailablePhone" Label="Phone" />
                            <MudCheckBox T="bool" @bind-Checked="Ref1AvailableBoth" Label="Both" />
                            <MudText Typo="Typo.body2">Best time to contact:</MudText>
                            <MudDatePicker @bind-Date="Ref1BestDate" DateFormat="MM/dd/yyyy" Class="w-25" />
                            <MudTimePicker @bind-Time="Ref1BestTime" Class="w-25" />
                        </MudItem>
                    </MudGrid>
                </MudItem>

                <MudDivider Class="my-4" />

                <!-- Reference 2 -->
                <MudItem xs="12" Class="mb-2">
                    <MudGrid>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="Reference2FullName" Placeholder="Full Name of Reference #2*" FullWidth="true" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <div class="d-flex" style="gap:8px; align-items:center;">
                                <MudText Typo="Typo.body2">Professional Relationship*</MudText>
                                <MudCheckBox T="bool" @bind-Checked="Ref2Colleague" Label="Colleague" />
                                <MudCheckBox T="bool" @bind-Checked="Ref2Superior" Label="Superior" />
                                <MudCheckBox T="bool" @bind-Checked="Ref2Peer" Label="Peer" />
                                <MudCheckBox T="bool" @bind-Checked="Ref2Subordinate" Label="Subordinate" />
                            </div>
                        </MudItem>

                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="Reference2Company" Placeholder="Affiliated Company*" FullWidth="true" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="Reference2Email" Placeholder="Email Contact Information*" FullWidth="true" />
                        </MudItem>

                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="Reference2Mobile" Placeholder="Mobile Contact Information*" FullWidth="true" />
                        </MudItem>

                        <MudItem xs="12" sm="6" Class="d-flex" Style="gap:12px; align-items:center;">
                            <MudText Typo="Typo.body2">Available to reach on:</MudText>
                            <MudCheckBox T="bool" @bind-Checked="Ref2AvailableEmail" Label="Email" />
                            <MudCheckBox T="bool" @bind-Checked="Ref2AvailablePhone" Label="Phone" />
                            <MudCheckBox T="bool" @bind-Checked="Ref2AvailableBoth" Label="Both" />
                            <MudText Typo="Typo.body2">Best time to contact:</MudText>
                            <MudDatePicker @bind-Date="Ref2BestDate" DateFormat="MM/dd/yyyy" Class="w-25" />
                            <MudTimePicker @bind-Time="Ref2BestTime" Class="w-25" />
                        </MudItem>
                    </MudGrid>
                </MudItem>

                <MudItem xs="12" Class="d-flex align-center" Style="gap:12px; margin-top:12px;">
                    <MudText Typo="Typo.body2">Add another reference?</MudText>
                    <MudCheckBox T="bool" @bind-Checked="AddAnotherReference" />
                </MudItem>

                <MudItem xs="12" Class="d-flex justify-end mt-6">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveAndNextAsync">Save & Next</MudButton>
                </MudItem>
            </MudGrid>
        </MudStep>

        <MudStep Title="Part 2 - Application Examination">
            <MudGrid Class="pa-6">
                <MudItem xs="12">
                    <MudText Typo="Typo.subtitle1" Align="Align.Center" Class="mb-6">Application Examination</MudText>
                </MudItem>

                <MudItem xs="12" sm="4">
                    <MudPaper Class="pa-6 d-flex flex-column align-center" Style="text-align:center; border-radius:8px;">
                        <MudImage Src="/images/ats/exam-icon-0.png" Alt="exam icon 0" Style="width:120px; height:120px; object-fit:contain;" />
                        <MudText Typo="Typo.subtitle2" Class="mt-3">Application Examination</MudText>
                        <MudButton Class="mt-3" Variant="Variant.Filled" Color="Color.Primary" Disabled="@ExamStarted[0]" OnClick="() => OnTakeTest(0)">Take Test</MudButton>

                        <div class="d-flex flex-column mt-4" style="gap:8px; align-items:center;">
                            <div class="d-flex" style="gap:8px; align-items:center;">
                                <MudIcon Icon="Icons.Material.Filled.Schedule" />
                                <MudText Typo="Typo.caption">20:00 minutes</MudText>
                            </div>
                            <div class="d-flex" style="gap:8px; align-items:center;">
                                <MudIcon Icon="@(ExamStatuses[0] == "Not Started" ? Icons.Material.Filled.RadioButtonUnchecked : Icons.Material.Filled.PlayCircle)" />
                                <MudText Typo="Typo.caption">@ExamStatuses[0]</MudText>
                            </div>
                        </div>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" sm="4">
                    <MudPaper Class="pa-6 d-flex flex-column align-center" Style="text-align:center; border-radius:8px;">
                        <MudImage Src="/images/ats/exam-icon-1.png" Alt="exam icon 1" Style="width:120px; height:120px; object-fit:contain;" />
                        <MudText Typo="Typo.subtitle2" Class="mt-3">Application Examination</MudText>
                        <MudButton Class="mt-3" Variant="Variant.Filled" Color="Color.Primary" Disabled="@ExamStarted[1]" OnClick="() => OnTakeTest(1)">Take Test</MudButton>

                        <div class="d-flex flex-column mt-4" style="gap:8px; align-items:center;">
                            <div class="d-flex" style="gap:8px; align-items:center;">
                                <MudIcon Icon="Icons.Material.Filled.Schedule" />
                                <MudText Typo="Typo.caption">20:00 minutes</MudText>
                            </div>
                            <div class="d-flex" style="gap:8px; align-items:center;">
                                <MudIcon Icon="@(ExamStatuses[1] == "Not Started" ? Icons.Material.Filled.RadioButtonUnchecked : Icons.Material.Filled.PlayCircle)" />
                                <MudText Typo="Typo.caption">@ExamStatuses[1]</MudText>
                            </div>
                        </div>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" sm="4">
                    <MudPaper Class="pa-6 d-flex flex-column align-center" Style="text-align:center; border-radius:8px;">
                        <MudImage Src="/images/ats/exam-icon-2.png" Alt="exam icon 2" Style="width:120px; height:120px; object-fit:contain;" />
                        <MudText Typo="Typo.subtitle2" Class="mt-3">Application Examination</MudText>
                        <MudButton Class="mt-3" Variant="Variant.Filled" Color="Color.Primary" Disabled="@ExamStarted[2]" OnClick="() => OnTakeTest(2)">Take Test</MudButton>

                        <div class="d-flex flex-column mt-4" style="gap:8px; align-items:center;">
                            <div class="d-flex" style="gap:8px; align-items:center;">
                                <MudIcon Icon="Icons.Material.Filled.Schedule" />
                                <MudText Typo="Typo.caption">20:00 minutes</MudText>
                            </div>
                            <div class="d-flex" style="gap:8px; align-items:center;">
                                <MudIcon Icon="@(ExamStatuses[2] == "Not Started" ? Icons.Material.Filled.RadioButtonUnchecked : Icons.Material.Filled.PlayCircle)" />
                                <MudText Typo="Typo.caption">@ExamStatuses[2]</MudText>
                            </div>
                        </div>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        </MudStep>

        <MudStep Title="Part 3 - Initial Interview">
            <MudGrid>
                <MudItem xs="12">
                    <MudText Typo="Typo.subtitle1" Align="Align.Center" Class="mb-4">Initial Interview</MudText>
                </MudItem>

                <MudItem xs="12" sm="8">
                    <MudPaper Class="pa-4" Style="height:420px; display:flex; align-items:center; justify-content:center; border:6px solid #0b66a3; background:#fff;">
                        <MudImage Src="/images/ats/interview-photo.png" Alt="Interview photo" Style="max-width:100%; max-height:100%; object-fit:cover;" />
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" sm="4">
                    <div style="display:flex; flex-direction:column; gap:12px; padding:12px;">
                        <MudText Typo="Typo.body1">Test your microphone and audio<br/>Try moving the bars below</MudText>

                        <div class="d-flex" style="align-items:center; gap:12px;">
                            <MudIcon Icon="Icons.Material.Filled.Mic" />
                            <MudSlider @bind-Value="MicLevel" Min="0" Max="100" Step="1" Style="flex:1" />
                            <MudText Typo="Typo.caption">@MicLevel% </MudText>
                        </div>

                        <div class="d-flex" style="align-items:center; gap:12px;">
                            <MudIcon Icon="Icons.Material.Filled.SpeakerPhone" />
                            <MudSlider @bind-Value="SpeakerLevel" Min="0" Max="100" Step="1" Style="flex:1" />
                            <MudText Typo="Typo.caption">@SpeakerLevel% </MudText>
                        </div>

                        <div class="d-flex" style="align-items:center; gap:12px;">
                            <MudIcon Icon="Icons.Material.Filled.VolumeUp" />
                            <MudSlider @bind-Value="VolumeLevel" Min="0" Max="100" Step="1" Style="flex:1" />
                            <MudText Typo="Typo.caption">@VolumeLevel% </MudText>
                        </div>

                        <div style="margin-top:18px;">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="StartInterview">Start Interview</MudButton>
                        </div>
                    </div>
                </MudItem>

                <MudItem xs="12" Class="d-flex justify-end mt-4">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveAndNextAsync">Save & Next</MudButton>
                </MudItem>
            </MudGrid>
        </MudStep>

        <MudStep Title="Final">
            <MudGrid>
                <MudItem xs="12">
                    <MudText Typo="Typo.subtitle1" Align="Align.Center" Class="mb-4">Consent to Collect and Disclose</MudText>
                </MudItem>

                <MudItem xs="12">
                    <MudPaper Class="pa-4" Style="height:320px; overflow:auto; background:#f9fbfd;">
                        <MudText Typo="Typo.body2">
                            I hereby give authorization and consent for CIBI Information Inc. ("CIBI"), acting on behalf of the company, to access and disclose information about me as stated below which may be in any national, provincial, regional or city files, including those maintained by both public and private organizations, and all public records, for the purpose of validating my identity, checking on the truthfulness of the declarations made and the authenticity of documents submitted to the Company.
                        </MudText>
                        <MudText Typo="Typo.body2" Class="mt-2">
                            I authorize CIBI to obtain and verify information relating to my employment history, education records, licences, civil and criminal records, and to contact listed references or previous employers for purposes related to the background screening and verification process. I understand that such information will be used only for evaluation of my application and will be treated in accordance with applicable privacy laws.
                        </MudText>
                        <MudText Typo="Typo.body2" Class="mt-2">
                            I understand that the information obtained will be kept confidential and will only be disclosed to authorized personnel involved in the recruitment and screening process. I release CIBI and its agents from any liability arising from the lawful collection and use of such information.
                        </MudText>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" Class="mt-4">
                    <MudText Typo="Typo.subtitle2">Release and Discharge</MudText>
                    <MudText Typo="Typo.body2" Class="mt-2">I consent to the release of the information described above and hereby discharge any person or entity from liability for providing such information to CIBI or the Company.</MudText>
                </MudItem>

                <MudItem xs="12" Class="mt-4">
                    <MudGrid>
                        <MudItem xs="12" sm="4">
                            <MudTextField @bind-Value="SignatureText" Placeholder="Signature" FullWidth="true" />
                        </MudItem>
                        <MudItem xs="12" sm="4">
                            <MudTextField @bind-Value="SignerName" Placeholder="Name" FullWidth="true" />
                        </MudItem>
                        <MudItem xs="12" sm="4">
                            <MudDatePicker @bind-Date="SignatureDate" Placeholder="Date" DateFormat="MM/dd/yyyy" Class="w-100" />
                        </MudItem>
                    </MudGrid>
                </MudItem>

                <MudItem xs="12" Class="d-flex justify-end mt-6">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="@(string.IsNullOrWhiteSpace(SignatureText) || string.IsNullOrWhiteSpace(SignerName))" OnClick="SubmitForm">Submit</MudButton>
                </MudItem>
            </MudGrid>
        </MudStep>
    </MudStepper>
</MudPaper>

@code {
    // Stepper and general
    private MudStepper? _stepper;
    private string? statusMessage;

    // Step 1
    private bool consent = false;
    private bool declineConsent = false;

    // Step 2 - personal information fields
    private string? PositionAppliedFor;
    private string? FirstName;
    private string? MiddleName;
    private bool NoMiddleName;
    private string? LastName;
    private string? Suffix;
    private DateTime? DateOfBirth;
    private string? Sex;
    private string? AlternateEmail;
    private string? PhoneNumber;

    // Step 3 - address and education
    private string? CurrentAddressLine;
    private string? CurrentCity;
    private string? CurrentState;
    private string? CurrentCountry;
    private string? CurrentZip;

    private bool SameAsPermanent;

    private string? PermanentAddressLine;
    private string? PermanentCity;
    private string? PermanentState;
    private string? PermanentCountry;
    private string? PermanentZip;

    // Ownership
    private bool OwnershipOwned;
    private bool OwnershipRent;
    private bool OwnershipLivingWithFamily;
    private bool OwnershipOthers;
    private string? OwnershipOtherText;

    // Educational background
    private string? HighestEducationalAttainment;
    private DateTime? GraduationDate;
    private string? DegreeWithMajor;
    private string? AcademicInstitution;

    // Uploaded files
    private IBrowserFile? BiometricFile;
    private IBrowserFile? GovtIdFile;
    private IBrowserFile? NbiFile;
    private IBrowserFile? CvFile;
    private IBrowserFile? DiplomaFile;

    // Step 4 - credentials & experience
    private string? ProfessionalLicense;
    private DateTime? LicenseExpiryDate;
    private string? LicenseNumber;
    private IBrowserFile? ProfessionalLicenseFile;

    private string? CompanyName;
    private bool CurrentlyEmployed;
    private bool WithPermissionToContact;
    private string? CompanyCity;
    private string? CompanyState;
    private string? CompanyCountry;
    private string? CompanyZip;
    private DateTime? DatePermittedToContact;
    private string? JobTitle;
    private DateTime? StartOfEmployment;
    private DateTime? EndOfEmployment;
    private string? SupervisorName;
    private string? ContactInformation;
    private IBrowserFile? CoeFile;
    private bool AddAnotherEmployer;

    // Step 5 - references
    private string? Reference1FullName;
    private bool Ref1Colleague;
    private bool Ref1Superior;
    private bool Ref1Peer;
    private bool Ref1Subordinate;
    private string? Reference1Company;
    private string? Reference1Email;
    private string? Reference1Mobile;
    private bool Ref1AvailableEmail;
    private bool Ref1AvailablePhone;
    private bool Ref1AvailableBoth;
    private DateTime? Ref1BestDate;
    private TimeSpan? Ref1BestTime;

    private string? Reference2FullName;
    private bool Ref2Colleague;
    private bool Ref2Superior;
    private bool Ref2Peer;
    private bool Ref2Subordinate;
    private string? Reference2Company;
    private string? Reference2Email;
    private string? Reference2Mobile;
    private bool Ref2AvailableEmail;
    private bool Ref2AvailablePhone;
    private bool Ref2AvailableBoth;
    private DateTime? Ref2BestDate;
    private TimeSpan? Ref2BestTime;
    private bool AddAnotherReference;

    // Part 2 - examinations
    private string[] ExamStatuses = new[] { "Not Started", "Not Started", "Not Started" };
    private bool[] ExamStarted = new[] { false, false, false };

    private void OnTakeTest(int index)
    {
        if (index < 0 || index >= ExamStarted.Length)
            return;
        ExamStarted[index] = true;
        ExamStatuses[index] = "In Progress";
        // TODO: wire navigation to the actual exam flow or open a modal
    }

    // Part 3 - initial interview
    private int MicLevel { get; set; } = 50;
    private int SpeakerLevel { get; set; } = 25;
    private int VolumeLevel { get; set; } = 75;

    private void StartInterview()
    {
        statusMessage = "Interview started";
        // TODO: implement interview start behavior (webcam/microphone access, modal, or navigation)
    }

    private async Task SkipStep()
    {
        if (_stepper is not null)
            await _stepper.SkipCurrentStepAsync();
    }

    private async Task ResetStepper()
    {
        if (_stepper is not null)
            await _stepper.ResetAsync();
    }

    private async Task ProceedClicked()
    {
        if (_stepper is not null)
            await _stepper.NextStepAsync();
    }

    private Task OnBiometricUpload(InputFileChangeEventArgs e)
    {
        BiometricFile = e.File;
        statusMessage = BiometricFile?.Name;
        return Task.CompletedTask;
    }

    private Task OnGovtIdUpload(InputFileChangeEventArgs e)
    {
        GovtIdFile = e.File;
        statusMessage = GovtIdFile?.Name;
        return Task.CompletedTask;
    }

    private Task OnNbiUpload(InputFileChangeEventArgs e)
    {
        NbiFile = e.File;
        statusMessage = NbiFile?.Name;
        return Task.CompletedTask;
    }

    private Task OnCvUpload(InputFileChangeEventArgs e)
    {
        CvFile = e.File;
        statusMessage = CvFile?.Name;
        return Task.CompletedTask;
    }

    private Task OnDiplomaUpload(InputFileChangeEventArgs e)
    {
        DiplomaFile = e.File;
        statusMessage = DiplomaFile?.Name;
        return Task.CompletedTask;
    }

    private Task OnProfessionalLicenseUpload(InputFileChangeEventArgs e)
    {
        ProfessionalLicenseFile = e.File;
        statusMessage = ProfessionalLicenseFile?.Name;
        return Task.CompletedTask;
    }

    private Task OnCoeUpload(InputFileChangeEventArgs e)
    {
        CoeFile = e.File;
        statusMessage = CoeFile?.Name;
        return Task.CompletedTask;
    }

    private void OnSameAsPermanentChanged()
    {
        if (SameAsPermanent)
        {
            PermanentAddressLine = CurrentAddressLine;
            PermanentCity = CurrentCity;
            PermanentState = CurrentState;
            PermanentCountry = CurrentCountry;
            PermanentZip = CurrentZip;
        }
    }

    private async Task SaveAndNextAsync()
    {
        // TODO: add validation and save logic here
        statusMessage = "Saved";
        if (_stepper is not null)
            await _stepper.NextStepAsync();
    }

    // Final step - signature fields
    private string? SignatureText;
    private string? SignerName;
    private DateTime? SignatureDate = DateTime.Today;

    private async Task SubmitForm()
    {
        // TODO: send form data to backend API
        statusMessage = "Form submitted";
        if (_stepper is not null)
            await _stepper.NextStepAsync();
    }
}
