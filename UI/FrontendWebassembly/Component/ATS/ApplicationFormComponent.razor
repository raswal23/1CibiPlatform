<MudPaper Style="border-radius:20px; overflow:hidden; box-shadow:0px 10px 45px rgba(0,0,0,0.1); max-width:1200px; min-width:800px; min-height:600px; margin: 5px;">
    @if(!showPhilSys)
    {
        <MudStepper @ref="_stepper" @bind-ActiveIndex="_activeStep" Class="custom-stepper">
            <ChildContent>
                <!-- STEP 1 -->
                <MudStep Title="Part 1 - Step 1">
                    <MudPaper Style="margin:100px;" Elevation="0">
                        <MudGrid Justify="Justify.Center"
                                 AlignItems="AlignItems.Center">
                            <MudItem xs="12" sm="7" Class="d-flex justify-center align-center">
                                <div class="d-flex flex-column align-center text-center" style="height:100%; justify-content:center; padding:24px;">
                                    <MudText Typo="Typo.h5" Style="font-weight:700;" Class="gradient-text">Get your identity verified using your PSA's live national ID verification free of charge!</MudText>
                                    <div class="mt-4 d-flex" style="align-items:center; gap:16px; justify-content:center ">
                                        <MudImage Src="/images/ats/philippine-id.png" Alt="Philippine Identification System" Style="max-width:500px; height:auto;" />
                                    </div>
                                </div>
                            </MudItem>

                            <MudItem xs="12" sm="5">
                                <div style=" display:flex; align-items:center; padding:18px;">
                                    <MudPaper Class="pa-4" Style="background:linear-gradient(180deg,#f2fbff,#e6f7fb); box-shadow: 0 0 10px rgba(42,119,174,0.8); width:100%; border-radius:8px;">
                                        <MudText Typo="Typo.subtitle1" Style="font-weight:700;" Class="mb-2 gradient-text">IMPORTANT NOTICE!</MudText>
                                        <MudText Typo="Typo.body2" Class="mb-3">
                                            I am a registered PSA National ID member and I voluntarily consent to share my verified information to any prospective employer I am applying for.
                                        </MudText>
                                        <div class="d-flex flex-column align-center justify-center mt-4">
                                            <MudCheckBox T="bool" @bind-Value="consent" Label=" Yes, I agree and wish to proceed." />
                                            <MudButton Disabled="!consent"
                                                       Class="@($"mb-4 theme-button {(consent ? "theme-button-active " : "theme-button-inactive")}")"
                                                       Style="width: 150px; border-radius: 4px;"
                                                       OnClick="ProceedClicked">
                                                Proceed
                                            </MudButton>

                                            <MudCheckBox T="bool"
                                                         @bind-Value="declineConsent"
                                                         Label="No, I do not wish to proceed." />
                                            <div class="d-flex" style="gap:30px;">
                                                <MudButton Style="background-color:gray; color:white; border-radius: 4px;" OnClick="SkipStep">Skip</MudButton>
                                                <MudButton Style="background-color:gray; color:white; border-radius: 4px;" OnClick="ResetStepper">Cancel</MudButton>
                                            </div>
                                        </div>
                                    </MudPaper>
                                </div>

                            </MudItem>
                        </MudGrid>
                    </MudPaper>
                    
                </MudStep>

                <!-- STEP 2 -->
                <MudStep Title="Part 1 - Step 2">
                    <MudText Typo="Typo.h6" Align="Align.Center" Style="font-weight:700;" Class="mb-4 mt-4 gradient-text">Personal Information</MudText>
                    <MudGrid>
                        <!-- Left column: Personal information fields -->
                        <MudItem xs="12" sm="6">
                            <MudPaper Class="pa-4" Elevation="0">
                                <MudGrid>
                                    <MudItem xs="12">
                                        <MudTextField FullWidth="true"
                                                      Adornment="Adornment.Start"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense"
                                                      @bind-Value="PositionAppliedFor"
                                                      Class="oneplatform-rounded-input"
                                                      Label="Position Applied For" />
                                    </MudItem>

                                    <MudItem xs="12">
                                        <MudTextField FullWidth="true"
                                                      Adornment="Adornment.Start"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense"
                                                      @bind-Value="FirstName"
                                                      Class="oneplatform-rounded-input"
                                                      Label="First Name" />
                                    </MudItem>
                                    <MudItem xs="12" sm="6">
                                        <MudTextField FullWidth="true"
                                                      Adornment="Adornment.Start"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense"
                                                      @bind-Value="MiddleName"
                                                      Class="oneplatform-rounded-input"
                                                      Label="Middle Name" />
                                    </MudItem>
                                    <MudItem xs="12" sm="6" Class="d-flex align-center">
                                        <div style="display:flex; align-items:center; gap:8px; width:100%;">
                                            <MudCheckBox T="bool"
                                                         @bind-Checked="NoMiddleName"
                                                         Label="Check if no Middle Name"
                                                         Class="small-checkbox-label" />
                                        </div>
                                    </MudItem>

                                    <MudItem xs="12">
                                        <MudTextField FullWidth="true"
                                                      Adornment="Adornment.Start"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense"
                                                      @bind-Value="LastName"
                                                      Class="oneplatform-rounded-input"
                                                      Label="Last Name" />
                                    </MudItem>
                                    <MudItem xs="12" sm="4">
                                        <MudTextField FullWidth="true"
                                                      Adornment="Adornment.Start"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense"
                                                      @bind-Value="Suffix"
                                                      Class="oneplatform-rounded-input"
                                                      Label="Suffix" />
                                    </MudItem>
                                    <MudItem xs="12" sm="4">
                                        <MudDatePicker @bind-Date="DateOfBirth"
                                                       Label="Birth Date"
                                                       Adornment="Adornment.End"
                                                       Required="true"
                                                       RequiredError="Birth Date is required"
                                                       Variant="Variant.Outlined"
                                                       Margin="Margin.Dense"
                                                       DateFormat="MM/dd/yyyy"
                                                       Class="oneplatform-rounded-input" />
                                    </MudItem>

                                    <MudItem xs="12" sm="4">
                                        <MudSelect T="string"
                                                   @bind-Value="Sex"
                                                   Class="oneplatform-rounded-input"
                                                   Adornment="Adornment.Start"
                                                   Variant="Variant.Outlined"
                                                   Margin="Margin.Dense"
                                                   Label="Sex"
                                                   FullWidth="true">
                                            <MudSelectItem Value="@("Male")">Male</MudSelectItem>
                                            <MudSelectItem Value="@("Female")">Female</MudSelectItem>
                                            <MudSelectItem Value="@("Prefer not to say")">Prefer not to say</MudSelectItem>
                                        </MudSelect>
                                    </MudItem>

                                    <MudItem xs="12">
                                        <MudTextField FullWidth="true"
                                                      Adornment="Adornment.Start"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense"
                                                      @bind-Value="AlternateEmail"
                                                      Class="oneplatform-rounded-input"
                                                      Label="Alternate Email Address" />
                                    </MudItem>

                                    <MudItem xs="12">
                                        <MudTextField FullWidth="true"
                                                      Adornment="Adornment.Start"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense"
                                                      @bind-Value="PhoneNumber"
                                                      Class="oneplatform-rounded-input"
                                                      Label="Phone Number" />
                                    </MudItem>
                                </MudGrid>
                            </MudPaper>
                        </MudItem>

                        <MudItem xs="12" sm="6">
                            <MudPaper Class="pa-10" Elevation="0" Style=" height: 540px; background:linear-gradient(180deg,#f2fbff,#e6f7fb); box-shadow: 0 0 10px rgba(42,119,174,0.8); width:100%; border-radius:8px;">
                                <div class="d-flex flex-column align-center" style="gap:12px;">
                                    <MudImage Src="images/generic/default_picture.jpg"
                                              Alt="User Profile"
                                              Style="height: 200px; width: 200px; object-fit: cover; border-radius: 50%; outline: 2px solid #000;" />
                                    <MudText Typo="Typo.subtitle1">Biometric Image</MudText>

                                    <div class="d-flex flex-column" style="width:100%; margin-top:12px; gap:8px;">
                                        <MudFileUpload @ref="@GovernmentUploadIdFile"
                                                       @bind-Files="GovernmentIdFile"
                                                       Accept=".xls,.xlsx,.csv"
                                                       DragAndDrop="true">
                                            <CustomContent>
                                                <div style="display: flex; justify-content: center;">
                                                    <MudFab Class="oneplatform-rounded-input"
                                                            StartIcon="@Icons.Material.Filled.CloudUpload"
                                                            Style="width:300px; border: 1px solid gray; border-radius: 4px;"
                                                            OnClick="@context.OpenFilePickerAsync"
                                                            Label="Upload Unexpired Government ID" />
                                                </div>
                                            </CustomContent>
                                            <SelectedTemplate />
                                        </MudFileUpload>

                                        <MudFileUpload @ref="@NBIClearanceUploadFile"
                                                       @bind-Files="NBIClearanceFile"
                                                       Accept=".xls,.xlsx,.csv"
                                                       DragAndDrop="true"
                                                       Class="mt-4">
                                            <CustomContent>
                                                <div style="display: flex; justify-content: center;">
                                                    <MudFab Class="oneplatform-rounded-input"
                                                            StartIcon="@Icons.Material.Filled.CloudUpload"
                                                            Style="width:300px; border: 1px solid gray; border-radius: 4px;"
                                                            OnClick="@context.OpenFilePickerAsync"
                                                            Label="Upload NBI Clearance" />
                                                </div>
                                            </CustomContent>
                                            <SelectedTemplate />
                                        </MudFileUpload>

                                        <MudFileUpload @ref="@CVOrResumeUploadFile"
                                                       @bind-Files="CVOrResumeFile"
                                                       Accept=".xls,.xlsx,.csv"
                                                       DragAndDrop="true"
                                                       Class="mt-4">
                                            <CustomContent>
                                                <div style="display: flex; justify-content: center;">
                                                    <MudFab Class="oneplatform-rounded-input"
                                                            StartIcon="@Icons.Material.Filled.CloudUpload"
                                                            Style="width:300px; border: 1px solid gray; border-radius: 4px;"
                                                            OnClick="@context.OpenFilePickerAsync"
                                                            Label="Upload CV / Resume" />
                                                </div>
                                            </CustomContent>
                                            <SelectedTemplate />
                                        </MudFileUpload>
                                    </div>
                                </div>
                            </MudPaper>
                        </MudItem>
                    </MudGrid>
                </MudStep>

                <!-- STEP 3 -->
                <MudStep Title="Part 1 - Step 3">
                    <MudText Typo="Typo.h6" Align="Align.Center" Style="font-weight:700;" Class="mb-4 mt-4 gradient-text">Address</MudText>
                    <MudGrid>
                        <!-- Address section -->
                        <MudItem xs="12" sm="4">
                            <MudTextField FullWidth="true"
                                          Adornment="Adornment.Start"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Class="oneplatform-rounded-input"
                                          @bind-Value="CurrentAddressLine"
                                          Label="Current Address (No., Street, Village, Brgy.)" />
                        </MudItem>
                        <MudItem xs="12" sm="2">
                            <MudTextField FullWidth="true"
                                          Adornment="Adornment.Start"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Class="oneplatform-rounded-input"
                                          @bind-Value="CurrentCity"
                                          Label="City" />
                        </MudItem>
                        <MudItem xs="12" sm="2">
                            <MudTextField FullWidth="true"
                                          Adornment="Adornment.Start"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Class="oneplatform-rounded-input"
                                          @bind-Value="CurrentState"
                                          Label="State / Province / Region" />
                        </MudItem>
                        <MudItem xs="12" sm="2">
                            <MudTextField FullWidth="true"
                                          Adornment="Adornment.Start"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Class="oneplatform-rounded-input"
                                          @bind-Value="CurrentCountry"
                                          Label="Country" />
                        </MudItem>
                        <MudItem xs="12" sm="2">
                            <MudTextField FullWidth="true"
                                          Adornment="Adornment.Start"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Class="oneplatform-rounded-input"
                                          @bind-Value="CurrentZip"
                                          Label="Zip / Postal Code" />
                        </MudItem>

                        <MudItem xs="12" Style="margin-bottom:-10px;">
                            <MudCheckBox T="bool" Class="small-checkbox-label" Style="margin-bottom:-12px;" @bind-Checked="SameAsPermanent" Label="Check if current address is the same as permanent address" />
                        </MudItem>

                        <MudItem xs="12" sm="4">
                            <MudTextField FullWidth="true"
                                          Adornment="Adornment.Start"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Class="oneplatform-rounded-input"
                                          @bind-Value="PermanentAddressLine"
                                          Label="Permanent Address (No., Street, Village, Brgy.)" />
                        </MudItem>
                        <MudItem xs="12" sm="2">
                            <MudTextField FullWidth="true"
                                          Adornment="Adornment.Start"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Class="oneplatform-rounded-input"
                                          @bind-Value="PermanentCity"
                                          Label="City" />
                        </MudItem>
                        <MudItem xs="12" sm="2">
                            <MudTextField FullWidth="true"
                                          Adornment="Adornment.Start"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Class="oneplatform-rounded-input"
                                          @bind-Value="PermanentState"
                                          Label="State / Province / Region" />
                        </MudItem>
                        <MudItem xs="12" sm="2">
                            <MudTextField FullWidth="true"
                                          Adornment="Adornment.Start"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Class="oneplatform-rounded-input"
                                          @bind-Value="PermanentCountry"
                                          Label="Country" />
                        </MudItem>
                        <MudItem xs="12" sm="2">
                            <MudTextField FullWidth="true"
                                          Adornment="Adornment.Start"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Class="oneplatform-rounded-input"
                                          @bind-Value="PermanentZip"
                                          Label="Zip / Postal Code" />
                        </MudItem>

                        <!-- Ownership -->
                        <MudItem xs="12">
                            <MudText Typo="Typo.subtitle1" Align="Align.Left">Type of Ownership</MudText>
                            <div class="d-flex" style="gap:12px; flex-wrap:wrap;">
                                <MudRadioGroup T="string"
                                               @bind-Value="OwnershipType"
                                               Class="d-flex flex-wrap"
                                               Style="gap:12px;">

                                    <MudRadio T="string" Class="small-checkbox-label" Value="@("Owned")">
                                        Owned
                                    </MudRadio>
                                    <MudRadio T="string" Class="small-checkbox-label" Value="@("Rent")">
                                        Rent
                                    </MudRadio>
                                    <MudRadio T="string" Class="small-checkbox-label" Value="@("Living with family / relatives")">
                                        Living with family / relatives
                                    </MudRadio>
                                    <MudRadio T="string" Class="small-checkbox-label" Value="@("Others")">
                                        Others
                                    </MudRadio>
                                    @if (OwnershipType == "Others")
                                    {
                                        <MudTextField Adornment="Adornment.Start"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense"
                                                      Style="width:200px;"
                                                      Class="oneplatform-rounded-input ml-2"
                                                      @bind-Value="OwnershipOtherText"
                                                      Label="Please specify" />
                                    }
                                </MudRadioGroup>
                            </div>
                        </MudItem>

                        <!-- Educational Background -->
                        <MudItem xs="12">
                            <MudText Typo="Typo.h6" Class="gradient-text" Style="font-weight:700;" Align="Align.Center">Educational Background</MudText>
                        </MudItem>

                        <MudItem xs="12" sm="6">
                            <MudTextField FullWidth="true"
                                          Adornment="Adornment.Start"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Class="oneplatform-rounded-input"
                                          @bind-Value="HighestEducationalAttainment"
                                          Label="Highest Educational Attainment" />
                        </MudItem>
                        <MudItem xs="12" sm="3">
                            <MudDatePicker Label="Graduation Date"
                                           Adornment="Adornment.End"
                                           Required="true"
                                           Variant="Variant.Outlined"
                                           Margin="Margin.Dense"
                                           Class="oneplatform-rounded-input"
                                           @bind-Date="GraduationDate"
                                           DateFormat="MM/dd/yyyy" />
                        </MudItem>

                        <MudItem xs="12" sm="6">
                            <MudTextField FullWidth="true"
                                          Adornment="Adornment.Start"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Class="oneplatform-rounded-input"
                                          @bind-Value="DegreeWithMajor"
                                          Label="Degree with major" />
                        </MudItem>

                        <MudItem xs="12" sm="6">
                            <MudFileUpload @ref="@DiplomaORTORUploadFile"
                                           @bind-Files="DiplomaORTORFile"
                                           Accept=".xls,.xlsx,.csv"
                                           DragAndDrop="true">
                                <CustomContent>
                                    <MudFab Class="oneplatform-rounded-input"
                                            StartIcon="@Icons.Material.Filled.CloudUpload"
                                            Style="border: 1px solid gray; border-radius: 4px; width: 270px;"
                                            OnClick="@context.OpenFilePickerAsync"
                                            Label="Upload Diploma / TOR" />
                                </CustomContent>
                                <SelectedTemplate />
                            </MudFileUpload>
                        </MudItem>

                        <MudItem xs="12" sm="6">
                            <MudTextField FullWidth="true"
                                          Adornment="Adornment.Start"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Class="oneplatform-rounded-input"
                                          @bind-Value="AcademicInstitution"
                                          Label="Academic Institution" />
                        </MudItem>
                    </MudGrid>
                </MudStep>

                <!-- STEP 4 -->
                <MudStep Title="Part 1 - Step 4">
                    <MudText Typo="Typo.h6" Style="font-weight:700;" Align="Align.Center" Class="mt-4 mb-4 gradient-text">Credentials &amp; Licenses</MudText>
                    <MudGrid>
                        <MudItem xs="12" sm="8">
                            <MudTextField FullWidth="true"
                                          Adornment="Adornment.Start"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Class="oneplatform-rounded-input"
                                          @bind-Value="ProfessionalLicense"
                                          Label="Professional License" />
                        </MudItem>
                        <MudItem xs="12" sm="4">
                            <MudDatePicker Adornment="Adornment.End"
                                           Required="true"
                                           Variant="Variant.Outlined"
                                           Margin="Margin.Dense"
                                           Class="oneplatform-rounded-input"
                                           @bind-Date="LicenseExpiryDate"
                                           Label="License Expiry Date"
                                           DateFormat="MM/dd/yyyy" />
                        </MudItem>

                        <MudItem xs="12" sm="8">
                            <MudTextField FullWidth="true"
                                          Adornment="Adornment.Start"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Class="oneplatform-rounded-input"
                                          @bind-Value="LicenseNumber"
                                          Label="License No." />
                        </MudItem>

                        <MudItem xs="12" sm="4">
                            <MudFileUpload @ref="@ProfessionalLicenseUploadFile"
                                           @bind-Files="ProfessionalLicenseFile"
                                           Accept=".xls,.xlsx,.csv"
                                           DragAndDrop="true">
                                <CustomContent>
                                    <MudFab Class="oneplatform-rounded-input"
                                            StartIcon="@Icons.Material.Filled.CloudUpload"
                                            Style="border: 1px solid gray; border-radius: 4px; width: 368px;"
                                            OnClick="@context.OpenFilePickerAsync"
                                            Label="Upload Professional License" />
                                </CustomContent>
                                <SelectedTemplate />
                            </MudFileUpload>
                        </MudItem>

                        <MudItem xs="12">
                            <MudText Typo="Typo.h6" Class="gradient-text" Style="font-weight:700;" Align="Align.Center">Professional Experiences</MudText>
                        </MudItem>

                        <MudItem xs="12" sm="6">
                            <MudTextField FullWidth="true"
                                          Adornment="Adornment.Start"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Class="oneplatform-rounded-input"
                                          @bind-Value="CompanyName"
                                          Label="Company Name" />
                        </MudItem>

                        <MudItem xs="12" sm="6" Class="d-flex" Style="gap:12px;">
                            <MudCheckBox T="bool" @bind-Checked="CurrentlyEmployed" Class="small-checkbox-label" Label="Currently Employed?" />
                            <MudCheckBox T="bool" @bind-Checked="WithPermissionToContact" Class="small-checkbox-label" Label="With permission to contact?" />
                        </MudItem>

                        <MudItem xs="12" sm="4">
                            <MudTextField FullWidth="true"
                                          Adornment="Adornment.Start"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Class="oneplatform-rounded-input"
                                          @bind-Value="CompanyCity"
                                          Label="Company City / Address" />
                        </MudItem>
                        <MudItem xs="12" sm="3">
                            <MudTextField FullWidth="true"
                                          Adornment="Adornment.Start"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Class="oneplatform-rounded-input"
                                          @bind-Value="CompanyState"
                                          Label="State / Province / Region" />
                        </MudItem>
                        <MudItem xs="6" sm="2">
                            <MudTextField FullWidth="true"
                                          Adornment="Adornment.Start"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Class="oneplatform-rounded-input"
                                          @bind-Value="CompanyCountry"
                                          Label="Country" />
                        </MudItem>
                        <MudItem xs="6" sm="1">
                            <MudTextField FullWidth="true"
                                          Adornment="Adornment.Start"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Class="oneplatform-rounded-input"
                                          @bind-Value="CompanyZip"
                                          Label="Zip / Postal Code" />
                        </MudItem>
                        <MudItem xs="12" sm="2">
                            <MudDatePicker @bind-Date="DatePermittedToContact"
                                           Label="Date permitted to contact"
                                           DateFormat="MM/dd/yyyy"
                                           Adornment="Adornment.End"
                                           Required="true"
                                           Variant="Variant.Outlined"
                                           Margin="Margin.Dense"
                                           Class="oneplatform-rounded-input" />
                        </MudItem>

                        <MudItem xs="12" sm="3">
                            <MudTextField FullWidth="true"
                                          Adornment="Adornment.Start"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Class="oneplatform-rounded-input"
                                          @bind-Value="JobTitle"
                                          Label="Job Title" />
                        </MudItem>
                        <MudItem xs="12" sm="3">
                            <MudDatePicker DateFormat="MM/dd/yyyy"
                                           Adornment="Adornment.End"
                                           Required="true"
                                           Variant="Variant.Outlined"
                                           Margin="Margin.Dense"
                                           Class="oneplatform-rounded-input"
                                           Label="Start Date of Employment" />
                        </MudItem>
                        <MudItem xs="12" sm="3">
                            <MudDatePicker @bind-Date="EndOfEmployment"
                                           Adornment="Adornment.End"
                                           Required="true"
                                           Variant="Variant.Outlined"
                                           Margin="Margin.Dense"
                                           Class="oneplatform-rounded-input"
                                           Label="End Date of Employment"
                                           DateFormat="MM/dd/yyyy" />
                        </MudItem>

                        <MudItem xs="12" sm="3" Class="mt-2">
                            <MudFileUpload @ref="@COEIdUploadFile"
                                           @bind-Files="COEIdFile"
                                           Accept=".xls,.xlsx,.csv"
                                           DragAndDrop="true">
                                <CustomContent>
                                    <MudFab Class="oneplatform-rounded-input"
                                            StartIcon="@Icons.Material.Filled.CloudUpload"
                                            Style="border: 1px solid gray; border-radius: 4px; width: 270px;"
                                            OnClick="@context.OpenFilePickerAsync"
                                            Label="Upload COE/ID" />
                                </CustomContent>
                                <SelectedTemplate />
                            </MudFileUpload>
                        </MudItem>

                        <MudItem xs="12" sm="6">
                            <MudTextField FullWidth="true"
                                          Adornment="Adornment.Start"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Class="oneplatform-rounded-input"
                                          @bind-Value="SupervisorName"
                                          Label="Supervisor Name" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField FullWidth="true"
                                          Adornment="Adornment.Start"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Class="oneplatform-rounded-input"
                                          @bind-Value="ContactInformation"
                                          Label="Contact Information" />
                        </MudItem>

                        <MudItem xs="12" Class="d-flex align-center justify-center">
                            <MudText Typo="Typo.body2">Add another employer?</MudText>
