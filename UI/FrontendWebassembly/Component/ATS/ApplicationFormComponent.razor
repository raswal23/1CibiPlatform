                                                           Required="true"
                                                           RequiredError="Professional Relationship is required"
                                                           @bind-Value="referenceDetails.Ref2ProfessionalRelationship"
                                                           Class="d-flex flex-wrap"
                                                           Style="gap:12px;">

                                                <MudRadio T="string" Class="small-checkbox-label" Value="@("Colleague")">
                                                    Colleague
                                                </MudRadio>
                                                <MudRadio T="string" Class="small-checkbox-label" Value="@("Superior")">
                                                    Superior
                                                </MudRadio>
                                                <MudRadio T="string" Class="small-checkbox-label" Value="@("Peer")">
                                                    Peer
                                                </MudRadio>
                                                <MudRadio T="string" Class="small-checkbox-label" Value="@("Subordinate")">
                                                    Subordinate
