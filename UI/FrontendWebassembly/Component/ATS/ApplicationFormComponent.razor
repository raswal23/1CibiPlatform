                            <!-- Reference 2 -->
                            <MudItem xs="12">
                                <MudGrid>
                                    <MudItem xs="12" sm="6">
                                        <MudTextField FullWidth="true"
                                                      Adornment="Adornment.Start"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense"
                                                      Required="true"
                                                      Class="oneplatform-rounded-input"
                                                      @bind-Value="referenceDetails.Ref2FullName"
                                                      Label="Full Name of Reference #2" />
                                    </MudItem>
                                    <MudItem xs="12" sm="6">
                                        <div class="d-flex" style="gap:8px; align-items:center;">
