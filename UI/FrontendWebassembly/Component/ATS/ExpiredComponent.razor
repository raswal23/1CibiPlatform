<MudPaper Elevation="6"
          Class="p-10 text-center d-flex flex-column justify-center align-center"
          Style="border-radius:20px; padding: 15px; box-shadow:0px 10px 45px rgba(0,0,0,0.1); width:500px; max-width:90%;">

    <MudIcon Icon="@Icons.Material.Filled.HourglassEmpty"
             Size="Size.Large"
             Style="font-size: 80px; color: #d9534f; margin-bottom: 20px;" />

    <MudText Typo="Typo.h4" Style="font-weight: bold; margin-bottom: 10px;">
        Session Expired
    </MudText>

    <MudText Typo="Typo.subtitle1" Style="max-width: 420px; color: #555;  margin: 0px 10px 20px 10px;">
        Your application form session has expired.
    </MudText>

   
</MudPaper>

