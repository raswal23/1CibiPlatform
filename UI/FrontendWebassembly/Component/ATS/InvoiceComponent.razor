<MudGrid GutterSize="3" Class="mb-4">
    <MudItem xs="12" md="6">
        <MudPaper Elevation="1" Class="pa-4 mb-3" Style="border-radius: 4px; box-shadow: 0 0 10px rgba(42,119,174,0.8);">
            <MudText Typo="Typo.subtitle1" Align="Align.Center" Class="mb-5 gradient-text" Style="font-size: 20px; font-weight:700;">
                Billed Date
            </MudText>
            <div class="d-flex flex-column align-center" style="gap:12px;">
                <MudDatePicker Class="oneplatform-rounded-input" 
                               Label="Billed Date" 
                               ReadOnly
                               @bind-Date="_date" 
                               Mask="@(new DateMask("MM/dd/yyyy"))" 
                               DateFormat="MM/dd/yyyy" 
                               Variant="Variant.Outlined" />
            </div>
        </MudPaper>

        <MudPaper Elevation="1" Class="pa-4" Style="border-radius: 4px; box-shadow: 0 0 10px rgba(42,119,174,0.8); min-height: 467px; max-height: 467px;">
            <MudText Typo="Typo.subtitle1" Align="Align.Center" Class="mb-5 gradient-text" Style="font-size: 20px; font-weight:700;">
                Summary Details
            </MudText>

            <MudGrid Spacing="2">

                <MudItem xs="4" class="d-flex align-center">
                    <MudText>Billing Statement</MudText>
                </MudItem>
                <MudItem xs="8">
                    <MudTextField @bind-Value="bill.BillingStatement"
                                  Variant="Variant.Outlined"
                                  FullWidth="true"
                                  Class="oneplatform-rounded-input" />
                </MudItem>

                <MudItem xs="4" class="d-flex align-center">
                    <MudText>Due Date</MudText>
                </MudItem>
                <MudItem xs="8">
                    <MudTextField @bind-Value="bill.DueDate"
                                  Variant="Variant.Outlined"
                                  FullWidth="true"
                                  Class="oneplatform-rounded-input" />
                </MudItem>

                <MudItem xs="4" class="d-flex align-center">
                    <MudText>Amount Due</MudText>
                </MudItem>
                <MudItem xs="8">
                    <MudTextField @bind-Value="bill.AmountDue"
                                  Variant="Variant.Outlined"
                                  FullWidth="true"
                                  Class="oneplatform-rounded-input" />
                </MudItem>

                <MudItem xs="4" class="d-flex align-center">
                    <MudText>Previous Balance</MudText>
                </MudItem>
                <MudItem xs="8">
                    <MudTextField @bind-Value="bill.PreviousBalance"
                                  Variant="Variant.Outlined"
                                  FullWidth="true"
                                  Class="oneplatform-rounded-input" />
                </MudItem>

                <MudItem xs="4" class="d-flex align-center">
                    <MudText>Total Amount Due</MudText>
                </MudItem>
                <MudItem xs="8">
                    <MudTextField @bind-Value="bill.TotalAmountDue"
                                  Variant="Variant.Outlined"
                                  FullWidth="true"
                                  Class="oneplatform-rounded-input" />
                </MudItem>

                <MudItem xs="12" Class="d-flex justify-center">
                    <MudButton Class="theme-button theme-button-active" Style="width: 200px; border-radius: 4px;" OnClick="ProcessBulkInvite">Download Statement</MudButton>
                </MudItem>
            </MudGrid>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="6">
        <MudPaper Elevation="1" Class="pa-4" Style="height: auto; min-height: 635px; max-height:650px; border-radius: 4px; box-shadow: 0 0 10px rgba(42,119,174,0.8);">
            <MudText Typo="Typo.subtitle1" Align="Align.Center" Class="mb-5 gradient-text" Style="font-size: 20px; font-weight:700;">
                Payment Options
            </MudText>

            <MudGrid Spacing="2" Justify="Justify.Center" Style="max-height: 300px;">
                <!-- Payment via Credit Cards -->
                <MudItem xs="12" class="d-flex align-center justify-center">
                    <MudButton Class="theme-button theme-button-active" Style="width: 80px; border-radius: 4px;" OnClick="ProcessBulkInvite">Pay</MudButton>
                    <MudText>
                        <MudText Class="ml-2">via major credit cards</MudText>
                    </MudText>
                </MudItem>
                <MudItem xs="12" class="d-flex justify-center">
                    <MudImage Src="/images/ats/CreditCard.jpg"
                              Alt="Credit Cards"
                              Style="width:60%; max-height: 125px; min-height:125px;" />
                </MudItem>

                <!-- Payment via E-Wallets -->
                <MudItem xs="12" class="d-flex align-center justify-center">
                    <MudButton Class="theme-button theme-button-active" Style="width: 80px; border-radius: 4px;" OnClick="ProcessBulkInvite">Pay</MudButton>
                    <MudText Class="ml-2">via major e-wallets</MudText>
                </MudItem>
                <MudItem xs="12" class="d-flex justify-center">
                    <MudImage Src="/images/ats/CreditCard.jpg"
                              Alt="E-Wallets"
                              Style="width:60%; max-height: 125px; min-height:125px;" />
                </MudItem>

                <!-- Payment via Bank Transfer -->
                <MudItem xs="12" class="d-flex align-center justify-center">
                    <MudButton Class="theme-button theme-button-active" Style="width: 80px; border-radius: 4px;" OnClick="ProcessBulkInvite">Pay</MudButton>
                    <MudText Class="ml-2">via bank transfer</MudText>
                </MudItem>
                <MudItem xs="12" class="d-flex justify-center">
                    <MudImage Src="/images/ats/CreditCard.jpg"
                              Alt="Bank Transfer"
                              Style="width:60%; max-height: 125px; min-height:125px;" />
                </MudItem>
            </MudGrid>
        </MudPaper>
    </MudItem>
</MudGrid>

