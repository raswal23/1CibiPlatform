@using MudBlazor

<MudDialog Style="padding: 8px;">
    <DialogContent>

        <TableComponent TItem="List<string>"
                        Items="Rows">

            <HeaderTemplate>
                @foreach (var header in Headers)
                {
                    <MudTh>@header</MudTh>
                }
            </HeaderTemplate>

            <RowTemplate Context="row">
                @foreach (var cell in row)
                {
                    <MudTd>@cell</MudTd>
                }
            </RowTemplate>

        </TableComponent>

    </DialogContent>

    <DialogActions>

        <MudButton Color="Color.Default"
                   OnClick="Cancel"
                   Style="border-radius: 4px;">
            Cancel
        </MudButton>

        <MudButton Color="Color.Primary"
                   OnClick="Confirm"
                   Class="theme-button theme-button-active"
                   Style="border-radius: 4px;">
            Confirm Upload
        </MudButton>

    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter]
    private IMudDialogInstance BulkPreviewDialog { get; set; } = default!;

    [Parameter]
    public List<string> Headers { get; set; } = [];

    [Parameter]
    public List<List<string>> Rows { get; set; } = [];

    private void Confirm()
    {
        BulkPreviewDialog.Close(DialogResult.Ok(true));
    }

    private void Cancel()
    {
        BulkPreviewDialog.Cancel();
    }
}