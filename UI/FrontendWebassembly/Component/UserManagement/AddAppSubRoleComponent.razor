@inject LocalStorageService LocalStorageService
@inject IUserManagementService UserManagementService

<MudDialog Style="padding: 8px;">
    <DialogContent>
        <MudForm @ref="form">

            <MudAutocomplete T="UsersDTO" Label="User" @bind-Value="selectedUser" SearchFunc="@SearchUsers" ToStringFunc="u => u?.email" Variant="Variant.Outlined" ProgressIndicatorColor="Color.Default" ShowProgressIndicator="true" Class="oneplatform-rounded-input"/>
            @if (showUserError)
            {
                <MudText Typo="Typo.caption" Color="Color.Error">User is required</MudText>
            }

            <MudAutocomplete T="ApplicationsDTO" Label="Application" @bind-Value="selectedApp" SearchFunc="@SearchApplications" ToStringFunc="a => a?.applicationName" Variant="Variant.Outlined" ProgressIndicatorColor="Color.Default" ShowProgressIndicator="true" Class="oneplatform-rounded-input"/>
            @if (showAppError)
            {
                <MudText Typo="Typo.caption" Color="Color.Error">Application is required</MudText>
            }

            <MudAutocomplete T="SubMenusDTO" Label="SubMenu" @bind-Value="selectedMenu" SearchFunc="@SearchSubMenus" ToStringFunc="s => s?.subMenuName" Variant="Variant.Outlined" ProgressIndicatorColor="Color.Default" ShowProgressIndicator="true" Class="oneplatform-rounded-input"/>
            @if (showSubMenuError)
            {
                <MudText Typo="Typo.caption" Color="Color.Error">SubMenu is required</MudText>
            }

            <MudAutocomplete T="RolesDTO" Label="Role" @bind-Value="selectedRole" SearchFunc="@SearchRoles" ToStringFunc="r => r?.roleName" Variant="Variant.Outlined" ProgressIndicatorColor="Color.Default" ShowProgressIndicator="true" Class="oneplatform-rounded-input"/>
            @if (showRoleError)
            {
                <MudText Typo="Typo.caption" Color="Color.Error">Role is required</MudText>
            }

        </MudForm>
    </DialogContent>

    <DialogActions>
        <MudButton Color="Color.Default" OnClick="Cancel"Style="border-radius: 4px;">
            Cancel
        </MudButton>
        <MudButton Color="Color.Primary" OnClick="Submit" Class="theme-button theme-button-active" Style="border-radius: 4px;">
            Save
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    private MudForm? form;
    private bool showUserError;
    private bool showAppError;
    private bool showSubMenuError;
    private bool showRoleError;

    private UsersDTO? selectedUser;
    private ApplicationsDTO? selectedApp;
    private SubMenusDTO? selectedMenu;
    private RolesDTO? selectedRole;

    [CascadingParameter] IMudDialogInstance? MudDialog { get; set; }
    [Parameter] public AddAppSubRoleDTO AppSubRole { get; set; } = new AddAppSubRoleDTO();

    private List<UsersDTO>? Users = new();
    private List<ApplicationsDTO>? Apps = new();
    private List<SubMenusDTO>? SubMenus = new();
    private List<RolesDTO>? Roles = new();

    void Cancel() => MudDialog!.Cancel();

    protected override async Task OnInitializedAsync()
    {
        AppSubRole.AssignedBy = await LocalStorageService.GetItemAsync<Guid>("UserId");

        Users = (await UserManagementService.GetUsersAsync(1, int.MaxValue)).Data.ToList();
        Apps = (await UserManagementService.GetApplicationsAsync(1, int.MaxValue)).Data.ToList();
        SubMenus = (await UserManagementService.GetSubMenusAsync(1, int.MaxValue)).Data.ToList();
        Roles = (await UserManagementService.GetRolesAsync(1, int.MaxValue)).Data.ToList();
    }

    async Task Submit()
    {
        showUserError = AppSubRole.UserId == Guid.Empty;
        showAppError = AppSubRole.AppId == 0;
        showSubMenuError = AppSubRole.SubMenuId == 0;
        showRoleError = AppSubRole.RoleId == 0;

        StateHasChanged();

        if (showUserError || showAppError || showSubMenuError || showRoleError)
            return;

        await form!.ValidateAsync();

        var notification = new AssignmentNotificationDTO
        {
            Gmail = Users?.FirstOrDefault(u => u.userId == AppSubRole.UserId)?.email,
            Application = Apps?.FirstOrDefault(a => a.applicationId == AppSubRole.AppId)?.applicationName,
            SubMenu = SubMenus?.FirstOrDefault(s => s.subMenuId == AppSubRole.SubMenuId)?.subMenuName,
            Role = Roles?.FirstOrDefault(r => r.roleId == AppSubRole.RoleId)?.roleName
        };

        AppSubRole.UserId = selectedUser?.userId ?? Guid.Empty;
        MudDialog!.Close(DialogResult.Ok(new AddAppSubRoleResult(AppSubRole, notification)));
    }

    private async Task<IEnumerable<UsersDTO>> SearchUsers(string value, CancellationToken token)
    {
        await Task.Delay(1000, token);

        if (string.IsNullOrEmpty(value))
            return Users!;
        return Users!.Where(u => u.email!.Contains(value, StringComparison.InvariantCultureIgnoreCase));
    }
    
    private async Task<IEnumerable<ApplicationsDTO>> SearchApplications(string value, CancellationToken token)
    {
        await Task.Delay(1000, token);

        if (string.IsNullOrEmpty(value))
            return Apps!;
        return Apps!.Where(a => a.applicationName!.Contains(value, StringComparison.InvariantCultureIgnoreCase));
    }

    private async Task<IEnumerable<SubMenusDTO>> SearchSubMenus(string value, CancellationToken token)
    {
        await Task.Delay(1000, token);

        if (string.IsNullOrEmpty(value))
            return SubMenus!;
        return SubMenus!.Where(s => s.subMenuName!.Contains(value, StringComparison.InvariantCultureIgnoreCase));
    }

    private async Task<IEnumerable<RolesDTO>> SearchRoles(string value, CancellationToken token)
    {
        await Task.Delay(1000, token);

        if (string.IsNullOrEmpty(value))
            return Roles!;
        return Roles!.Where(s => s.roleName!.Contains(value, StringComparison.InvariantCultureIgnoreCase));
    }
}
