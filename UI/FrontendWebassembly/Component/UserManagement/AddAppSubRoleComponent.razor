@inject LocalStorageService LocalStorageService
@inject IUserManagementService UserManagementService

<MudDialog Style="padding: 8px;">
    <DialogContent>
        <MudForm @ref="AddAppSubRoleForm">

            <MudAutocomplete T="UsersDTO" Label="User" @bind-Value="selectedUser" SearchFunc="@SearchUsers" ToStringFunc="u => u?.email" Variant="Variant.Outlined" ProgressIndicatorColor="Color.Default" ShowProgressIndicator="true" Class="oneplatform-rounded-input"/>
            @if (showUserError)
            {
                <MudText Typo="Typo.caption" Color="Color.Error">User is required</MudText>
            }

            <MudAutocomplete T="ApplicationsDTO" Label="Application" @bind-Value="selectedApp" SearchFunc="@SearchApplications" ToStringFunc="a => a?.applicationName" Variant="Variant.Outlined" ProgressIndicatorColor="Color.Default" ShowProgressIndicator="true" Class="oneplatform-rounded-input"/>
            @if (showAppError)
            {
                <MudText Typo="Typo.caption" Color="Color.Error">Application is required</MudText>
            }

            <MudAutocomplete T="SubMenusDTO" Label="SubMenu" @bind-Value="selectedMenu" SearchFunc="@SearchSubMenus" ToStringFunc="s => s?.subMenuName" Variant="Variant.Outlined" ProgressIndicatorColor="Color.Default" ShowProgressIndicator="true" Class="oneplatform-rounded-input"/>
            @if (showSubMenuError)
            {
                <MudText Typo="Typo.caption" Color="Color.Error">SubMenu is required</MudText>
            }

            <MudAutocomplete T="RolesDTO" Label="Role" @bind-Value="selectedRole" SearchFunc="@SearchRoles" ToStringFunc="r => r?.roleName" Variant="Variant.Outlined" ProgressIndicatorColor="Color.Default" ShowProgressIndicator="true" Class="oneplatform-rounded-input"/>
            @if (showRoleError)
            {
                <MudText Typo="Typo.caption" Color="Color.Error">Role is required</MudText>
            }

        </MudForm>
    </DialogContent>

    <DialogActions>
        <MudButton Color="Color.Default" OnClick="Cancel"Style="border-radius: 4px;">
            Cancel
        </MudButton>
        <MudButton Color="Color.Primary" OnClick="Submit" Class="theme-button theme-button-active" Style="border-radius: 4px;">
            Save
        </MudButton>
    </DialogActions>
</MudDialog>

