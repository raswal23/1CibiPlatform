<MudDialog Style="padding: 8px;">
    <DialogContent>
        <MudForm @ref="EditUserApprovalForm">
            <MudTextField @bind-Value="User.email"
                          Label="Email"
                          ReadOnly
                          Adornment="Adornment.Start"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          MaxLength="100"
                          Class="oneplatform-rounded-input philsys-uppercase-input" />
        </MudForm>
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Cancel"
                   Class="theme-button-delete"
                   Style="border-radius: 4px; border: 2px solid gray;">
            Disapprove
        </MudButton>
        <MudButton OnClick="Submit"
                   Class="theme-button theme-button-active"
                   Style="border-radius: 4px;">
            Approve
        </MudButton>
    </DialogActions>
</MudDialog>