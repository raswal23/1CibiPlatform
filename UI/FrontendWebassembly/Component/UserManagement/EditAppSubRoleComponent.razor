@inject LocalStorageService LocalStorageService
@inject IUserManagementService UserManagementService

<MudDialog Style="padding: 8px;">
    <DialogContent>

        @if (!IsLoaded)
        {
            <LoaderComponent Height="200px" />
        }
        else
        {
            <MudForm @ref="form">
                <MudAutocomplete T="UsersDTO" 
                                 Label="User" 
                                 @bind-Value="selectedUser" 
                                 SearchFunc="@SearchUsers" 
                                 ToStringFunc="u => u?.email" 
                                 Variant="Variant.Outlined" 
                                 ProgressIndicatorColor="Color.Default" 
                                 ShowProgressIndicator="true" 
                                 Class="oneplatform-rounded-input" />

                <MudAutocomplete T="ApplicationsDTO" 
                                 Label="Application" 
                                 @bind-Value="selectedApp" 
                                 SearchFunc="@SearchApplications" 
                                 ToStringFunc="a => a?.applicationName" 
                                 Variant="Variant.Outlined" 
                                 ProgressIndicatorColor="Color.Default" 
                                 ShowProgressIndicator="true" 
                                 Class="oneplatform-rounded-input" />

                <MudAutocomplete T="SubMenusDTO" 
                                 Label="SubMenu" 
                                 @bind-Value="selectedMenu" 
                                 SearchFunc="@SearchSubMenus" 
                                 ToStringFunc="s => s?.subMenuName" 
                                 Variant="Variant.Outlined" 
                                 ProgressIndicatorColor="Color.Default" 
                                 ShowProgressIndicator="true" 
                                 Class="oneplatform-rounded-input" />

                <MudAutocomplete T="RolesDTO" 
                                 Label="Role" 
                                 @bind-Value="selectedRole" 
                                 SearchFunc="@SearchRoles" 
                                 ToStringFunc="r => r?.roleName" 
                                 Variant="Variant.Outlined" 
                                 ProgressIndicatorColor="Color.Default" 
                                 ShowProgressIndicator="true" 
                                 Class="oneplatform-rounded-input" />
            </MudForm>
        }

    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Default"
                   OnClick="Cancel"
                   Style="border-radius: 4px;">
            Cancel
        </MudButton>
        <MudButton Color="Color.Primary"
                   OnClick="Submit"
                   Class="theme-button theme-button-active"
                   Style="border-radius: 4px;">
            Save
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    private MudForm? form;
    private bool IsLoaded = false;
    private UsersDTO? selectedUser;
    private ApplicationsDTO? selectedApp;
    private SubMenusDTO? selectedMenu;
    private RolesDTO? selectedRole;
    [CascadingParameter] IMudDialogInstance? MudDialog { get; set; }

    [Parameter]
    public AppSubRolesDTO AppSubRole { get; set; } = new AppSubRolesDTO();

    private List<UsersDTO>? Users = new();
    private List<ApplicationsDTO>? Apps = new();
    private List<SubMenusDTO>? SubMenus = new();
    private List<RolesDTO>? Roles = new();

    void Cancel() => MudDialog!.Cancel();

    protected override async Task OnInitializedAsync()
    {
        Users = (await UserManagementService.GetUsersAsync(1, int.MaxValue)).Data.ToList();
        Apps = (await UserManagementService.GetApplicationsAsync(1, int.MaxValue)).Data.ToList();
        SubMenus = (await UserManagementService.GetSubMenusAsync(1, int.MaxValue)).Data.ToList();
        Roles = (await UserManagementService.GetRolesAsync(1, int.MaxValue)).Data.ToList();

        selectedUser = Users?.FirstOrDefault(u => u.email == AppSubRole.UserEmail);
        selectedApp = Apps?.FirstOrDefault(a => a.applicationName == AppSubRole.AppName);
        selectedMenu = SubMenus?.FirstOrDefault(s => s.subMenuName == AppSubRole.SubMenuName);
        selectedRole = Roles?.FirstOrDefault(r => r.roleName == AppSubRole.RoleName);

        IsLoaded = true;
    }

    async Task Submit()
    {
        await form!.Validate();
        if (form.IsValid)
        {
            MudDialog!.Close(DialogResult.Ok(AppSubRole));
        }
    }

    
    private async Task<IEnumerable<UsersDTO>> SearchUsers(string value, CancellationToken token)
    {
        await Task.Delay(1000, token);

        if (string.IsNullOrEmpty(value))
            return Users!;
        return Users!.Where(u => u.email!.Contains(value, StringComparison.InvariantCultureIgnoreCase));
    }
    
    private async Task<IEnumerable<ApplicationsDTO>> SearchApplications(string value, CancellationToken token)
    {
        await Task.Delay(1000, token);

        if (string.IsNullOrEmpty(value))
            return Apps!;
        return Apps!.Where(a => a.applicationName!.Contains(value, StringComparison.InvariantCultureIgnoreCase));
    }

    private async Task<IEnumerable<SubMenusDTO>> SearchSubMenus(string value, CancellationToken token)
    {
        await Task.Delay(1000, token);

        if (string.IsNullOrEmpty(value))
            return SubMenus!;
        return SubMenus!.Where(s => s.subMenuName!.Contains(value, StringComparison.InvariantCultureIgnoreCase));
    }

    private async Task<IEnumerable<RolesDTO>> SearchRoles(string value, CancellationToken token)
    {
        await Task.Delay(1000, token);

        if (string.IsNullOrEmpty(value))
            return Roles!;
        return Roles!.Where(s => s.roleName!.Contains(value, StringComparison.InvariantCultureIgnoreCase));
    }
}