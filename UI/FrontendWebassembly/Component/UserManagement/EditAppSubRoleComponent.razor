@inject LocalStorageService LocalStorageService
@inject IUserManagementService UserManagementService

<MudDialog Style="padding: 8px;">
    <DialogContent>

        @if (!IsLoaded)
        {
            <LoaderComponent Height="200px" />
        }
        else
        {
            <MudForm @ref="EditAppSubRoleForm">
                <MudAutocomplete T="UsersDTO" 
                                 Label="User" 
                                 @bind-Value="selectedUser" 
                                 SearchFunc="@SearchUsers" 
                                 ToStringFunc="u => u?.email" 
                                 Variant="Variant.Outlined" 
                                 ProgressIndicatorColor="Color.Default" 
                                 ShowProgressIndicator="true" 
                                 Class="oneplatform-rounded-input" />

                <MudAutocomplete T="ApplicationsDTO" 
                                 Label="Application" 
                                 @bind-Value="selectedApp" 
                                 SearchFunc="@SearchApplications" 
                                 ToStringFunc="a => a?.applicationName" 
                                 Variant="Variant.Outlined" 
                                 ProgressIndicatorColor="Color.Default" 
                                 ShowProgressIndicator="true" 
                                 Class="oneplatform-rounded-input" />

                <MudAutocomplete T="SubMenusDTO" 
                                 Label="SubMenu" 
                                 @bind-Value="selectedMenu" 
                                 SearchFunc="@SearchSubMenus" 
                                 ToStringFunc="s => s?.subMenuName" 
                                 Variant="Variant.Outlined" 
                                 ProgressIndicatorColor="Color.Default" 
                                 ShowProgressIndicator="true" 
                                 Class="oneplatform-rounded-input" />

                <MudAutocomplete T="RolesDTO" 
                                 Label="Role" 
                                 @bind-Value="selectedRole" 
                                 SearchFunc="@SearchRoles" 
                                 ToStringFunc="r => r?.roleName" 
                                 Variant="Variant.Outlined" 
                                 ProgressIndicatorColor="Color.Default" 
                                 ShowProgressIndicator="true" 
                                 Class="oneplatform-rounded-input" />
            </MudForm>
        }

    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Default"
                   OnClick="Cancel"
                   Style="border-radius: 4px;">
            Cancel
        </MudButton>
        <MudButton Color="Color.Primary"
                   OnClick="Submit"
                   Class="theme-button theme-button-active"
                   Style="border-radius: 4px;">
            Save
        </MudButton>
    </DialogActions>
</MudDialog>