@inject NavigationManager NavigationManager

<MudPaper Elevation="6"
          Class="p-10 text-center d-flex flex-column justify-center align-center"
          Style="border-radius:20px; padding: 15px; box-shadow:0px 10px 45px rgba(0,0,0,0.1); width:500px; max-width:90%;">

    @if (IsCompleted)
    {
        <MudIcon Icon="@Icons.Material.Filled.ErrorOutline"
                 Size="Size.Large"
                 Style="font-size: 80px; color: #d9534f; margin-bottom: 20px;" />

        
        <MudText Typo="Typo.h4" Style="font-weight: bold; margin-bottom: 10px;" Class="gradient-text">
            Session Not Found
        </MudText>

        <MudText Typo="Typo.subtitle1" Style="max-width: 400px; color: #555; margin: 0px 10px 20px 10px;">
            This liveness verification link has already been completed or is no longer valid.
        </MudText>
    }
    else
    {
        <MudIcon Icon="@Icons.Material.Filled.HourglassEmpty"
                 Size="Size.Large"
                 Style="font-size: 80px; color: #d9534f; margin-bottom: 20px;" />

        <MudText Typo="Typo.h4" Style="font-weight: bold; margin-bottom: 10px;">
            Session Expired
        </MudText>

        <MudText Typo="Typo.subtitle1" Style="max-width: 420px; color: #555;  margin: 0px 10px 20px 10px;">
            Your liveness verification session has expired.
            Please start a new session to continue your PhilSys verification process.
        </MudText>
    }

    <ButtonComponent StartIcon="@Icons.Material.Filled.Refresh"
                     OnClick="StartNewSession"
                     Disabled="@DisableButton()"
                     Class="@(WebHookUrl == "/" ? "theme-button theme-button-active" : "theme-button theme-button-inactive")">
        Start New Session
    </ButtonComponent>
</MudPaper>
