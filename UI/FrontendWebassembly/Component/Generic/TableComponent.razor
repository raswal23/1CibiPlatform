@typeparam TItem

<div class="responsive-table-container">
@if (LoadServerData != null)
    {
        <MudTable T="TItem"
        @ref="TableRef"
        ServerData="LoadServerData"
        Class="responsive-title"
        HorizontalScrollbar="true"
        Hover="true"
        RowsPerPage="@(RowsPerPage ?? 10)"
        LoadingContent="@(UseLoadingContentBody ? null : LoadingContent)"
        LoadingContentBody="@(UseLoadingContentBody ? LoadingContentBody : null)"
        Style="border-radius: 4px; padding: 10px;">

            <ToolBarContent>
                @if (!string.IsNullOrWhiteSpace(Title))
                {
                    <MudText Typo="Typo.h6" Class="responsive-title gradient-text" Style="font-size: 20px; font-weight: 700;">@Title</MudText>
                }

                <MudSpacer />
                @if (EnableSearch)
                {
                    <MudTextField T="string"
                    Value="SearchString"
                    ValueChanged="@(EventCallback.Factory.Create<string>(this, SearchChanged))"
                    ValueExpression="(() => SearchString)"
                    Placeholder="Search"
                    Adornment="Adornment.Start"
                    AdornmentIcon="@Icons.Material.Filled.Search"
                    IconSize="Size.Medium"
                    Class="mt-0" />
                }

                @if (AddButtonText != null)
                {
                    <MudSpacer />
                    <MudButton Variant="Variant.Filled"
                    Class="theme-button theme-button-active"
                    StartIcon="@Icons.Material.Filled.Add"
                    Style="border-radius: 4px; margin-left:20px;"
                    OnClick="@OnAddClicked">
                        @AddButtonText
                    </MudButton>
                }
            </ToolBarContent>

            <HeaderContent>
                @HeaderTemplate
            </HeaderContent>

            <RowTemplate Context="item">
                @RowTemplate!(item)
            </RowTemplate>

            <NoRecordsContent>
                @NoRecordsTemplate
            </NoRecordsContent>

            <PagerContent>
                <MudTablePager />
            </PagerContent>
        </MudTable>
    }
else
    {
        <MudTable T="TItem"
                  @ref="TableRef"
                  Items="Items"
                  Hover="true"
                  Class="responsive-title"
                  Style="border-radius: 4px; padding: 10px;"
                  RowsPerPage="@(RowsPerPage ?? 10)"
                  HorizontalScrollbar="true">

            <HeaderContent>
                @HeaderTemplate
            </HeaderContent>

            <RowTemplate Context="item">
                @RowTemplate!(item)
            </RowTemplate>

            <NoRecordsContent>
                @NoRecordsTemplate
            </NoRecordsContent>

            <PagerContent>
                <MudTablePager />
            </PagerContent>

        </MudTable>
    }
</div>

@code {
    private readonly RenderFragment LoadingContent = @<MudSkeleton />;

    private RenderFragment LoadingContentBody => @<text>
            @for (int r = 0; r< 4; r++)
                {
                <MudTr>
                    @for (int c = 0; c<ColumnCount; c++)
                            {
                    <MudTd><MudSkeleton /></MudTd>
                            }
                </MudTr>
                }
            </text>;
}
