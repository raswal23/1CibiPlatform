<MudDialog>
    <DialogContent>
        <MudText>@Message</MudText>
    </DialogContent>

    <DialogActions>
        <MudButton Color="Color.Primary" OnClick="Confirm">
            Yes
        </MudButton>

        <MudButton OnClick="Cancel">
            No
        </MudButton>
    </DialogActions>
</MudDialog>

