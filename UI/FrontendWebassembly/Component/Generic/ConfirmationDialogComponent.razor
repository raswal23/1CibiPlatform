<MudDialog Style="padding: 8px;">
    <DialogContent>
        <MudText>@Message</MudText>
    </DialogContent>

    <DialogActions>
        <MudButton Class="theme-button theme-button-active mt-4"
                   Style="width:80px; border-radius: 4px;"
                   OnClick="Confirm">
            Yes
        </MudButton>

        <MudButton Style="width:80px; border-radius: 4px; border: 2px solid gray;"
                   Class="mt-4"
                   OnClick="Cancel">
            No
        </MudButton>
    </DialogActions>
</MudDialog>

