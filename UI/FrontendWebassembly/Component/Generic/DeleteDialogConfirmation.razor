<MudDialog Style="padding: 8px">
    <DialogContent>
        <MudText Typo="Typo.body1">@ContentText</MudText>
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Default" OnClick="Cancel">Cancel</MudButton>
        <MudButton Class="theme-button-delete"onclick ="Submit">@ButtonText</MudButton>
    </DialogActions>
</MudDialog>

