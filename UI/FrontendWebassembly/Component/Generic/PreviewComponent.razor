@inject IDialogService DialogService

<MudDialog Style="padding: 8px;">
    <DialogContent>

        <TableComponent TItem="List<string>"
                        Items="Rows">

            <HeaderTemplate>
                <MudTh>Cell Row</MudTh>

                @foreach (var header in Headers)
                {
                    <MudTh>@header</MudTh>
                }
            </HeaderTemplate>

            <RowTemplate Context="row">
                <MudTd DataLabel="Cell Row">@(Rows.IndexOf(row) + 2)</MudTd>

                @for (int i = 0; i < row.Count; i++)
                {
                    var cellColumn = row[i];

                    <MudTd DataLabel="@Headers[i]"
                           Style="@(string.IsNullOrWhiteSpace(cellColumn)
                                                          ? "color:#c62828;font-weight:bold;"
                                                          : "")">
                @(string.IsNullOrWhiteSpace(cellColumn) ? "(Blank)" : cellColumn)
                    </MudTd>
                }

            </RowTemplate>

        </TableComponent>

        <MudDivider Class="my-4" />

        @if (InvalidRows.Any())
        {
            <MudAlert 
                Severity="Severity.Error" 
                Dense="true"
                Class="mb-4">
                    Blank values found in row(s):
                    @string.Join(", ", InvalidRows) - 
                    @Message
            </MudAlert>
        }

        <MudStack Row
                  Justify="Justify.FlexEnd"
                  Spacing="2">

            <MudButton OnClick="Cancel"
                       Style="border-radius:4px; border: 2px solid gray;">
                Cancel
            </MudButton>


            <MudButton OnClick="Confirm"
                       Color="Color.Primary"
                       Disabled=InvalidRows.Any()
                       Class="theme-button theme-button-active"
                       Style="border-radius:4px;">
                Confirm Upload
            </MudButton>

        </MudStack>
    </DialogContent>
</MudDialog>

